            <!-- Wrong colors -->
            <div class="bg-surface-50 p-10 rounded border border-red-200 shadow-card flex flex-col items-center text-center overflow-hidden">
              <div class="text-red-500 mb-8 flex flex-col items-center">
                <svg class="w-10 h-10 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="font-bold text-lg uppercase tracking-wide">Utilizare Incorectă</span>
              </div>
              <div id="pdf-rule-wrongcolor" class="flex-1 flex items-center justify-center w-full overflow-hidden [&>div]:max-w-full [&>div]:scale-[0.55] [&>div]:origin-center md:[&>div]:scale-[0.65]" style="filter: hue-rotate(150deg) saturate(2);"></div>
              <p class="mt-8 text-surface-600 font-medium">Evitați modificarea culorilor aprobate.</p>
            </div>

            <!-- Tilted -->
            <div class="bg-surface-50 p-10 rounded border border-red-200 shadow-card flex flex-col items-center text-center overflow-hidden">
              <div class="text-red-500 mb-8 flex flex-col items-center">
                <svg class="w-10 h-10 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="font-bold text-lg uppercase tracking-wide">Utilizare Incorectă</span>
              </div>
              <div id="pdf-rule-tilted" class="flex-1 flex items-center justify-center w-full overflow-hidden [&>div]:max-w-full [&>div]:scale-[0.55] [&>div]:origin-center md:[&>div]:scale-[0.65]" style="transform: rotate(-15deg);"></div>
              <p class="mt-8 text-surface-600 font-medium">Evitați înclinarea siglei sau repoziționarea elementelor.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>

  <script>
    // ===== STATE =====
    const state = {
      step: 1,
      brandName: 'MINISTERUL DEZVOLTĂRII',
      symbols: { light: '', dark: '' },
      /** @type {{ hex: string, name: string, pantone: string }[]} */
      colors: [],
      fonts: { primary: 'Trajan Pro', secondary: 'Trebuchet MS' },
      safeZone: 0.2,
    };

    // ===== DOM REFS =====
    const $ = (/** @type {string} */ sel) => document.querySelector(sel);
    const $$ = (/** @type {string} */ sel) => document.querySelectorAll(sel);

    // ===== COLOR CONVERSION UTILITIES =====
    function hexToRgb(hex) {
      const h = hex.replace('#', '');
      const full = h.length === 3 ? h.split('').map(c => c + c).join('') : h;
      const r = parseInt(full.substring(0, 2), 16);
      const g = parseInt(full.substring(2, 4), 16);
      const b = parseInt(full.substring(4, 6), 16);
      return { r, g, b };
    }

    function rgbToCmyk(r, g, b) {
      if (r === 0 && g === 0 && b === 0) return { c: 0, m: 0, y: 0, k: 100 };
      const rr = r / 255, gg = g / 255, bb = b / 255;
      const k = 1 - Math.max(rr, gg, bb);
      const c = Math.round(((1 - rr - k) / (1 - k)) * 100);
      const m = Math.round(((1 - gg - k) / (1 - k)) * 100);
      const y = Math.round(((1 - bb - k) / (1 - k)) * 100);
      return { c, m, y, k: Math.round(k * 100) };
    }

    function getColorData(hex) {
      const { r, g, b } = hexToRgb(hex);
      const cmyk = rgbToCmyk(r, g, b);
      return {
        hex: hex.toUpperCase(),
        rgb: `${r}, ${g}, ${b}`,
        cmyk: `${cmyk.c}, ${cmyk.m}, ${cmyk.y}, ${cmyk.k}`,
      };
    }

    // ===== UTILITIES =====
    function splitInstitutionName(name) {
      if (!name) return [''];
      if (name.length <= 30) return [name];
      
      const words = name.split(' ');
      if (words.length === 1) return [name];

      let currentLength = 0;
      const targetLength = name.length / 2;
      let splitIndex = 1;

      for (let i = 0; i < words.length; i++) {
        currentLength += words[i].length + 1;
        if (currentLength >= targetLength && i > 0 && i < words.length - 1) {
          splitIndex = i + 1;
          break;
        }
      }

      const prepositions = ['ȘI', 'A', 'AL', 'ALE', 'AI', 'DE', 'PENTRU'];
      if (splitIndex < words.length && prepositions.includes(words[splitIndex].toUpperCase())) {
        splitIndex += 1;
      }

      const line1 = words.slice(0, splitIndex).join(' ');
      const line2 = words.slice(splitIndex).join(' ');
      return line2 ? [line1, line2] : [line1];
    }

    function buildLogoHTML(theme, orientation, { safeZone = 0.2 } = {}) {
      const symbolSvg = theme === 'light' ? state.symbols.light : state.symbols.dark;
      const textColor = theme === 'light' ? '#0F172A' : '#FFFFFF';
      const lines = splitInstitutionName(state.brandName);
      
      const symbolBaseSize = orientation === 'horizontal' ? 64 : 80;
      const dynamicGap = symbolBaseSize * safeZone;
      
      const symbolWrapperSize = orientation === 'horizontal' ? 'width:64px;height:64px;' : 'width:80px;height:80px;';

      if (orientation === 'symbol') {
        return `<div style="${symbolWrapperSize}" class="shrink-0 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full">${symbolSvg}</div>`;
      }

      const wrapperClass = orientation === 'horizontal' 
        ? 'flex flex-row items-center' 
        : 'flex flex-col items-center text-center';
      
      const textContainerClass = orientation === 'horizontal' 
        ? 'flex flex-col justify-center text-left' 
        : 'flex flex-col items-center text-center';

      const textHTML = lines.map((line, idx) => {
        const sizeClass = orientation === 'horizontal' 
          ? (idx === 0 ? 'text-lg' : 'text-base')
          : (idx === 0 ? 'text-xl' : 'text-lg mt-1');
        return `<span class="font-bold uppercase tracking-wide leading-tight whitespace-nowrap ${sizeClass}" style="font-family: ${state.fonts.primary}; color: ${textColor};">${line}</span>`;
      }).join('');

      return `
        <div class="${wrapperClass}" style="gap: ${dynamicGap}px;">
          <div style="${symbolWrapperSize}" class="shrink-0 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full">${symbolSvg}</div>
          <div class="${textContainerClass}">${textHTML}</div>
        </div>
      `;
    }

    // Larger logo for PDF pages (keeps original sizes)
    function buildLogoPdfHTML(theme, orientation, { safeZone = 0.2 } = {}) {
      const symbolSvg = theme === 'light' ? state.symbols.light : state.symbols.dark;
      const textColor = theme === 'light' ? '#0F172A' : '#FFFFFF';
      const lines = splitInstitutionName(state.brandName);
      
      const symbolBaseSize = orientation === 'horizontal' ? 96 : 128;
      const dynamicGap = symbolBaseSize * safeZone;
      
      const symbolWrapperSize = orientation === 'horizontal' ? 'width:96px;height:96px;' : 'width:128px;height:128px;';

      if (orientation === 'symbol') {
        return `<div style="${symbolWrapperSize}" class="shrink-0 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full">${symbolSvg}</div>`;
      }

      const wrapperClass = orientation === 'horizontal' 
        ? 'flex flex-row items-center' 
        : 'flex flex-col items-center text-center';
      
      const textContainerClass = orientation === 'horizontal' 
        ? 'flex flex-col justify-center text-left' 
        : 'flex flex-col items-center text-center';

      const textHTML = lines.map((line, idx) => {
        const sizeClass = orientation === 'horizontal' 
          ? (idx === 0 ? 'text-2xl' : 'text-xl')
          : (idx === 0 ? 'text-3xl' : 'text-2xl mt-1');
        return `<span class="font-bold uppercase tracking-wide leading-tight whitespace-nowrap ${sizeClass}" style="font-family: ${state.fonts.primary}; color: ${textColor};">${line}</span>`;
      }).join('');

      return `
        <div class="${wrapperClass}" style="gap: ${dynamicGap}px;">
          <div style="${symbolWrapperSize}" class="shrink-0 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full">${symbolSvg}</div>
          <div class="${textContainerClass}">${textHTML}</div>
        </div>
      `;
    }

    // ===== NAVIGATION =====
    // Steps: 1 (info+symbols), 2 (loading), 3 (colors), 4 (fonts), 5 (preview), 6 (PDF)
    function goToStep(step) {
      state.step = step;

      // Hide all panels
      $$('.step-panel').forEach(el => {
        el.classList.add('hidden');
        el.classList.remove('flex');
      });

      // Show target panel
      const panel = $(`#step-${step}`);
      if (panel) {
        panel.classList.remove('hidden');
        if (step === 2) panel.classList.add('flex');
      }

      // Update step indicators
      $$('[data-step-indicator]').forEach(el => {
        const s = parseInt(el.getAttribute('data-step-indicator') || '0');
        el.classList.toggle('text-primary-500', state.step >= s);
        el.classList.toggle('font-semibold', state.step >= s);
      });

      // Render step-specific content
      if (step === 4) renderTypographyPreview();
      if (step === 5) renderPreviews();
      if (step === 6) renderPDF();

      // Scroll to top
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    // @ts-ignore
    window.goToStep = goToStep;

    // ===== FILE UPLOAD =====
    function setupUpload(type) {
      const input = $(`#upload-${type}`);
      if (!input) return;
      input.addEventListener('change', (e) => {
        const file = /** @type {HTMLInputElement} */ (e.target).files?.[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
          const content = /** @type {string} */ (ev.target?.result);
          state.symbols[type] = content;

          // Update UI
          const zone = $(`#upload-${type}-zone`);
          const empty = $(`#upload-${type}-empty`);
          const preview = $(`#upload-${type}-preview`);
          const svgContainer = $(`#upload-${type}-svg`);

          if (zone) zone.classList.add('border-primary-500');
          if (empty) empty.classList.add('hidden');
          if (preview) { preview.classList.remove('hidden'); preview.classList.add('flex'); }
          if (svgContainer) svgContainer.innerHTML = content;

          // Enable analyze button if both loaded
          const btn = $('#btn-analyze');
          if (btn && state.symbols.light && state.symbols.dark) {
            /** @type {HTMLButtonElement} */ (btn).disabled = false;
          }
        };
        reader.readAsText(file);
      });
    }

    // ===== COLOR EXTRACTION =====
    function analyzeAndExtract() {
      goToStep(2);
      setTimeout(() => {
        const allSvgContent = state.symbols.light + state.symbols.dark;
        const hexRegex = /#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})\b/g;
        const matches = allSvgContent.match(hexRegex) || [];
        const uniqueColors = [...new Set(matches.map(c => c.toUpperCase()))];
        
        // Filter out pure white/black
        const filtered = uniqueColors.filter(c => c !== '#FFFFFF' && c !== '#FFF' && c !== '#000000' && c !== '#000');
        
        const hexList = filtered.length > 0 ? filtered : ['#004990', '#0079C1'];
        state.colors = hexList.map(hex => ({ hex, name: '', pantone: '' }));
        renderColors();
        goToStep(3);
      }, 1500);
    }
    // @ts-ignore
    window.analyzeAndExtract = analyzeAndExtract;

    // ===== RENDER: Colors (Rich format) =====
    function renderColors() {
      const grid = $('#colors-grid');
      if (!grid) return;

      let html = state.colors.map((colorObj, index) => {
        const data = getColorData(colorObj.hex);
        return `
        <div class="bg-surface-50 border border-surface-200 rounded p-0 overflow-hidden" data-color-idx="${index}">
          <div class="flex flex-col sm:flex-row">
            <!-- Color swatch -->
            <div class="w-full sm:w-36 h-28 sm:h-auto shrink-0 relative" style="background-color: ${colorObj.hex};">
              <input type="color" value="${colorObj.hex}" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer color-picker" data-idx="${index}" />
            </div>
            <!-- Color details -->
            <div class="flex-1 p-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              <div>
                <label class="text-[10px] font-bold text-surface-400 uppercase tracking-wider">HEX</label>
                <input type="text" value="${data.hex}" class="w-full border border-surface-200 rounded px-2 py-1.5 text-sm font-mono font-semibold uppercase focus:outline-none focus:border-primary-500 color-hex" data-idx="${index}" />
              </div>
              <div>
                <label class="text-[10px] font-bold text-surface-400 uppercase tracking-wider">RGB</label>
                <p class="text-sm font-mono text-surface-700 py-1.5">${data.rgb}</p>
              </div>
              <div>
                <label class="text-[10px] font-bold text-surface-400 uppercase tracking-wider">CMYK</label>
                <p class="text-sm font-mono text-surface-700 py-1.5">${data.cmyk}</p>
              </div>
              <div>
                <label class="text-[10px] font-bold text-surface-400 uppercase tracking-wider">Nume culoare <span class="text-surface-300">(opțional)</span></label>
                <input type="text" value="${colorObj.name}" placeholder="ex: Albastru instituțional" class="w-full border border-surface-200 rounded px-2 py-1.5 text-sm focus:outline-none focus:border-primary-500 color-name" data-idx="${index}" />
              </div>
              <div>
                <label class="text-[10px] font-bold text-surface-400 uppercase tracking-wider">Pantone <span class="text-surface-300">(opțional)</span></label>
                <input type="text" value="${colorObj.pantone}" placeholder="ex: Pantone 7462 C" class="w-full border border-surface-200 rounded px-2 py-1.5 text-sm focus:outline-none focus:border-primary-500 color-pantone" data-idx="${index}" />
              </div>
              <div class="flex items-end">
                <button class="text-red-400 hover:text-red-600 text-xs font-medium py-1.5 px-2 transition-colors color-remove" data-idx="${index}">✕ Elimină</button>
              </div>
            </div>
          </div>
        </div>
        `;
      }).join('');

      html += `
        <button id="add-color-btn" class="w-full rounded border-2 border-dashed border-surface-300 flex items-center justify-center text-surface-400 hover:text-primary-500 hover:border-primary-500 transition-colors py-6">
          <div class="flex items-center gap-2">
            <span class="text-2xl leading-none">+</span>
            <span class="text-sm font-medium">Adaugă culoare</span>
          </div>
        </button>
      `;

      grid.innerHTML = html;

      // Bind events
      grid.querySelectorAll('.color-picker').forEach(el => {
        el.addEventListener('input', (e) => {
          const idx = parseInt(/** @type {HTMLInputElement} */ (e.target).dataset.idx || '0');
          state.colors[idx].hex = /** @type {HTMLInputElement} */ (e.target).value.toUpperCase();
          renderColors();
        });
      });
      grid.querySelectorAll('.color-hex').forEach(el => {
        el.addEventListener('change', (e) => {
          const idx = parseInt(/** @type {HTMLInputElement} */ (e.target).dataset.idx || '0');
          const val = /** @type {HTMLInputElement} */ (e.target).value.toUpperCase();
          if (/^#[A-Fa-f0-9]{3,6}$/.test(val)) {
            state.colors[idx].hex = val;
            renderColors();
          }
        });
      });
      grid.querySelectorAll('.color-name').forEach(el => {
        el.addEventListener('change', (e) => {
          const idx = parseInt(/** @type {HTMLInputElement} */ (e.target).dataset.idx || '0');
          state.colors[idx].name = /** @type {HTMLInputElement} */ (e.target).value;
        });
      });
      grid.querySelectorAll('.color-pantone').forEach(el => {
        el.addEventListener('change', (e) => {
          const idx = parseInt(/** @type {HTMLInputElement} */ (e.target).dataset.idx || '0');
          state.colors[idx].pantone = /** @type {HTMLInputElement} */ (e.target).value;
        });
      });
      grid.querySelectorAll('.color-remove').forEach(el => {
        el.addEventListener('click', (e) => {
          const idx = parseInt(/** @type {HTMLElement} */ (e.currentTarget).dataset.idx || '0');
          if (state.colors.length > 1) {
            state.colors.splice(idx, 1);
            renderColors();
          }
        });
      });
      const addBtn = $('#add-color-btn');
      if (addBtn) {
        addBtn.addEventListener('click', () => {
          state.colors.push({ hex: '#CCCCCC', name: '', pantone: '' });
          renderColors();
        });
      }
    }

