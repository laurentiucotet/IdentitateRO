---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Generator Identitate Vizuală — IdentitateRO" description="Creați un manual de identitate vizuală complet pentru instituția dvs., direct în browser.">
  
  <!-- CDN libraries for PDF generation and ZIP download (loaded in head) -->
  <Fragment slot="head">
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.2/jspdf.umd.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
  </Fragment>

  <!-- Print-only styles -->
  <style is:global>
    @page {
      size: A4 portrait;
      margin: 0;
    }
    @media print {
      html, body {
        width: 210mm;
        height: 297mm;
        margin: 0 !important;
        padding: 0 !important;
        background: white !important;
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        color-adjust: exact !important;
      }
      header, footer, nav, .print\\:hidden, #wizard-header { display: none !important; }
      .print\\:block { display: block !important; }
      .pdf-page {
        width: 210mm !important;
        min-height: 297mm !important;
        height: 297mm !important;
        max-height: 297mm !important;
        page-break-after: always !important;
        break-after: page !important;
        overflow: hidden !important;
        box-sizing: border-box !important;
      }
      .pdf-page:last-child {
        page-break-after: auto !important;
        break-after: auto !important;
      }
      #pdf-content {
        box-shadow: none !important;
        border: none !important;
        border-radius: 0 !important;
        max-width: none !important;
        width: 210mm !important;
      }
      main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: none !important;
      }
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .animate-spinner { animation: spin 1s linear infinite; }
    
    /* PDF generation progress bar */
    .pdf-progress-bar {
      height: 6px;
      border-radius: 3px;
      background: #e2e8f0;
      overflow: hidden;
    }
    .pdf-progress-fill {
      height: 100%;
      border-radius: 3px;
      background: linear-gradient(90deg, #3b82f6, #2563eb);
      transition: width 0.3s ease;
    }
  </style>

  <!-- Wizard Header (steps indicator) -->
  <div id="wizard-header" class="bg-white border-b border-surface-200 px-4 sm:px-8 py-4 flex flex-wrap items-center justify-between gap-4 print:hidden">
    <div class="flex items-center gap-3 text-primary-500">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
      <h1 class="text-lg font-bold tracking-tight">Generator Identitate Vizuală</h1>
    </div>
    <nav class="flex flex-wrap items-center gap-2 text-xs font-medium text-surface-500" id="step-nav">
      <span data-step-indicator="1">1. Instituție & Simboluri</span>
      <span class="text-surface-300">/</span>
      <span data-step-indicator="3">2. Culori</span>
      <span class="text-surface-300">/</span>
      <span data-step-indicator="4">3. Fonturi</span>
      <span class="text-surface-300">/</span>
      <span data-step-indicator="5">4. Previzualizare</span>
      <span class="text-surface-300">/</span>
      <span data-step-indicator="6">5. Descărcare</span>
    </nav>
  </div>

  <main class="max-w-5xl mx-auto p-4 md:p-8 print:p-0 print:max-w-none">

    <!-- ==================== STEP 1: Institution Name + Symbol Upload (Combined) ==================== -->
    <section id="step-1" class="step-panel bg-white rounded shadow-card border border-surface-200 p-6 md:p-10 animate-fade-in print:hidden">
      <div class="mb-10 flex items-center gap-4 border-b border-surface-200 pb-6">
        <div class="bg-primary-50 p-3 rounded text-primary-500">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-primary-900">Informații Instituție & Simboluri</h2>
          <p class="text-surface-500 text-sm">Introduceți denumirea oficială și încărcați simbolurile SVG.</p>
        </div>
      </div>

      <!-- Institution Name -->
      <div class="mb-10">
        <label for="brand-name" class="block text-sm font-semibold text-primary-900 mb-3">Numele Oficial al Instituției</label>
        <input 
          type="text" 
          id="brand-name"
          value="MINISTERUL DEZVOLTĂRII"
          class="w-full border border-surface-200 rounded py-4 px-5 text-lg font-medium focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 uppercase"
          placeholder="EX: GUVERNUL ROMÂNIEI"
        />
        <div class="mt-6 p-6 bg-surface-50 border border-surface-200 rounded">
          <p class="text-xs text-surface-500 mb-3 font-semibold uppercase tracking-wider">Previzualizare Așezare Text</p>
          <div id="name-preview" class="flex flex-col text-xl font-bold text-primary-900 leading-tight"></div>
        </div>
      </div>

      <!-- Symbol Upload -->
      <div class="mb-10">
        <h3 class="text-sm font-semibold text-primary-900 mb-4">Încărcare Simboluri SVG</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Light symbol upload -->
          <div class="relative group">
            <input type="file" accept=".svg" id="upload-light" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
            <div id="upload-light-zone" class="border-2 border-dashed rounded p-8 flex flex-col items-center justify-center text-center transition-colors h-56 border-surface-300 hover:border-primary-500 bg-surface-50">
              <div id="upload-light-empty" class="flex flex-col items-center gap-3 text-surface-500 group-hover:text-primary-500 transition-colors">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                <span class="font-medium text-lg">Simbol Fundal Deschis</span>
                <span class="text-xs">Formă colorată sau închisă la culoare</span>
              </div>
              <div id="upload-light-preview" class="hidden flex-col items-center gap-4 w-full h-full">
                <div id="upload-light-svg" class="w-full flex-1 flex items-center justify-center p-4 bg-white rounded border border-surface-100 [&>svg]:max-w-full [&>svg]:max-h-full"></div>
                <span class="text-sm font-semibold text-green-600 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  Optimizat pentru fundal deschis
                </span>
              </div>
            </div>
          </div>

          <!-- Dark symbol upload -->
          <div class="relative group">
            <input type="file" accept=".svg" id="upload-dark" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
            <div id="upload-dark-zone" class="border-2 border-dashed rounded p-8 flex flex-col items-center justify-center text-center transition-colors h-56 border-surface-300 hover:border-primary-500 bg-surface-800">
              <div id="upload-dark-empty" class="flex flex-col items-center gap-3 text-surface-400 group-hover:text-primary-300 transition-colors">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                <span class="font-medium text-lg text-white">Simbol Fundal Închis</span>
                <span class="text-xs">Formă albă sau în culori luminoase</span>
              </div>
              <div id="upload-dark-preview" class="hidden flex-col items-center gap-4 w-full h-full">
                <div id="upload-dark-svg" class="w-full flex-1 flex items-center justify-center p-4 bg-surface-900 rounded [&>svg]:max-w-full [&>svg]:max-h-full"></div>
                <span class="text-sm font-semibold text-primary-300 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  Optimizat pentru fundal închis
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex justify-end">
        <button id="btn-analyze" onclick="analyzeAndExtract()" disabled class="btn-primary px-8 py-3 text-sm rounded flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
          Continuă — Analizare Culori
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        </button>
      </div>
    </section>

    <!-- ==================== STEP 2: Analyzing (loading) ==================== -->
    <section id="step-2" class="step-panel bg-white rounded shadow-card border border-surface-200 p-20 flex-col items-center justify-center text-center animate-fade-in print:hidden hidden">
      <div class="w-16 h-16 border-4 border-primary-100 border-t-primary-500 rounded-full animate-spinner mb-6"></div>
      <h2 class="text-2xl font-bold text-primary-900 mb-2">Se extrag datele...</h2>
      <p class="text-surface-500">Analizăm fișierele SVG pentru a identifica paleta de culori.</p>
    </section>

    <!-- ==================== STEP 3: Colors ==================== -->
    <section id="step-3" class="step-panel bg-white rounded shadow-card border border-surface-200 p-6 md:p-10 animate-fade-in print:hidden hidden">
      <div class="mb-10 flex items-center gap-4 border-b border-surface-200 pb-6">
        <div class="bg-primary-50 p-3 rounded text-primary-500">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-primary-900">Paleta de Culori</h2>
          <p class="text-surface-500 text-sm">Culorile extrase din SVG. Ajustați-le conform nevoilor.</p>
        </div>
      </div>

      <div id="colors-grid" class="flex flex-col gap-6 mb-10">
        <!-- Colors injected by JS (rich format with HEX, RGB, CMYK, optional name/pantone) -->
      </div>

      <div class="flex justify-between">
        <button onclick="goToStep(1)" class="btn-ghost px-6 py-3 text-sm">Înapoi</button>
        <button onclick="goToStep(4)" class="btn-primary px-8 py-3 text-sm rounded">Continuă</button>
      </div>
    </section>

    <!-- ==================== STEP 4: Typography ==================== -->
    <section id="step-4" class="step-panel bg-white rounded shadow-card border border-surface-200 p-6 md:p-10 animate-fade-in print:hidden hidden">
      <div class="mb-10 flex items-center gap-4 border-b border-surface-200 pb-6">
        <div class="bg-primary-50 p-3 rounded text-primary-500">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-primary-900">Tipografie</h2>
          <p class="text-surface-500 text-sm">Specificați fonturile utilizate pentru textul logo-ului și comunicarea oficială.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
        <div class="space-y-4">
          <label for="font-primary" class="block text-sm font-semibold text-primary-900">Font Principal (Nume Instituție)</label>
          <input 
            type="text" 
            id="font-primary"
            value="Trajan Pro"
            class="w-full border border-surface-200 rounded py-4 px-5 text-lg focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
          />
          <div class="p-6 bg-surface-50 rounded border border-surface-200 mt-4 flex items-center justify-center min-h-[120px]">
            <p id="font-primary-preview" class="text-2xl text-center uppercase tracking-wide leading-tight"></p>
          </div>
        </div>
        <div class="space-y-4">
          <label for="font-secondary" class="block text-sm font-semibold text-primary-900">Font Secundar (Texte uzuale)</label>
          <input 
            type="text" 
            id="font-secondary"
            value="Trebuchet MS"
            class="w-full border border-surface-200 rounded py-4 px-5 text-lg focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all"
          />
          <div class="p-6 bg-surface-50 rounded border border-surface-200 mt-4 min-h-[120px]">
            <p id="font-secondary-preview" class="text-lg text-surface-600 leading-relaxed">Acesta este un text de previzualizare a fontului secundar ales pentru documente.</p>
          </div>
        </div>
      </div>

      <div class="flex justify-between">
        <button onclick="goToStep(3)" class="btn-ghost px-6 py-3 text-sm">Înapoi</button>
        <button onclick="goToStep(5)" class="btn-primary px-8 py-3 text-sm rounded">Continuă</button>
      </div>
    </section>

    <!-- ==================== STEP 5: Preview & Safe Zone ==================== -->
    <section id="step-5" class="step-panel bg-white rounded shadow-card border border-surface-200 p-6 md:p-10 animate-fade-in print:hidden hidden">
      <div class="mb-10 flex items-center gap-4 border-b border-surface-200 pb-6">
        <div class="bg-primary-50 p-3 rounded text-primary-500">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" /></svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-primary-900">Previzualizare și Protecție</h2>
          <p class="text-surface-500 text-sm">Verificați variantele și ajustați spațiul de siguranță.</p>
        </div>
      </div>

      <div class="space-y-10 mb-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
          <!-- Light previews -->
          <div class="bg-white border border-surface-200 rounded p-6 md:p-10 flex flex-col items-center justify-center gap-8 shadow-card overflow-hidden">
            <h3 class="text-xs font-bold text-surface-400 uppercase tracking-widest mb-2">Orizontal & Vertical — Deschis</h3>
            <div id="preview-light-h" class="flex flex-row items-center w-full overflow-hidden justify-center [&>div]:max-w-full [&>div]:scale-[0.65] [&>div]:origin-center md:[&>div]:scale-75 lg:[&>div]:scale-90"></div>
            <div class="h-px w-full bg-surface-100"></div>
            <div id="preview-light-v" class="flex flex-col items-center text-center w-full overflow-hidden justify-center [&>div]:max-w-full [&>div]:scale-[0.65] [&>div]:origin-center md:[&>div]:scale-75 lg:[&>div]:scale-90"></div>
          </div>
          <!-- Dark previews -->
          <div class="bg-surface-900 border border-surface-800 rounded p-6 md:p-10 flex flex-col items-center justify-center gap-8 shadow-card overflow-hidden">
            <h3 class="text-xs font-bold text-surface-600 uppercase tracking-widest mb-2">Orizontal & Vertical — Închis</h3>
            <div id="preview-dark-h" class="flex flex-row items-center w-full overflow-hidden justify-center [&>div]:max-w-full [&>div]:scale-[0.65] [&>div]:origin-center md:[&>div]:scale-75 lg:[&>div]:scale-90"></div>
            <div class="h-px w-full bg-surface-800"></div>
            <div id="preview-dark-v" class="flex flex-col items-center text-center w-full overflow-hidden justify-center [&>div]:max-w-full [&>div]:scale-[0.65] [&>div]:origin-center md:[&>div]:scale-75 lg:[&>div]:scale-90"></div>
          </div>
        </div>

        <!-- Safe zone slider -->
        <div class="bg-surface-50 rounded p-8 border border-surface-200 flex flex-col justify-center">
          <h3 class="text-lg font-bold text-primary-900 mb-6">Setare Zonă de Protecție</h3>
          <div class="mb-8">
            <label for="safe-zone-range" class="block text-sm font-semibold text-primary-900 mb-4">Ajustare Proporție (<span id="safe-zone-label">20</span>%)</label>
            <input 
              type="range" 
              id="safe-zone-range"
              min="0.1" 
              max="1.0" 
              step="0.05" 
              value="0.2"
              class="w-full h-2 bg-surface-200 rounded-lg appearance-none cursor-pointer accent-primary-500"
            />
          </div>
          
          <div class="flex justify-center">
            <div id="safe-zone-demo" class="relative border-2 border-dashed border-primary-500 bg-white inline-flex items-center justify-center transition-all" style="padding: 20px;">
              <div class="absolute top-2 left-1/2 -translate-x-1/2 text-[10px] font-bold text-primary-500 uppercase whitespace-nowrap">Zonă Liberă</div>
              <div id="safe-zone-symbol" class="w-[100px] h-[100px] [&>svg]:w-full [&>svg]:h-full"></div>
            </div>
          </div>
          <p class="text-sm text-surface-500 text-center mt-6">Protejează lizibilitatea siglei pe documente oficiale.</p>
        </div>
      </div>

      <div class="flex flex-wrap justify-between border-t border-surface-200 pt-8 gap-4">
        <button onclick="goToStep(4)" class="btn-ghost px-6 py-3 text-sm">Înapoi</button>
        <div class="flex flex-wrap items-center gap-3">
          <button onclick="downloadSVGPack()" class="bg-indigo-600 text-white px-6 py-3 rounded font-medium text-sm flex items-center gap-2 hover:bg-indigo-700 transition-all shadow-md">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Descarcă Pachet SVG
          </button>
          <button onclick="goToStep(6)" class="bg-green-600 text-white px-8 py-3 rounded font-medium text-sm flex items-center gap-2 hover:bg-green-700 transition-all shadow-md">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            Generează Manualul PDF
          </button>
        </div>
      </div>
    </section>

    <!-- ==================== STEP 6: Generated PDF Manual ==================== -->
    <section id="step-6" class="step-panel animate-fade-in hidden">
      
      <!-- Toolbar (print:hidden) -->
      <div class="bg-white p-6 rounded shadow-card border border-surface-200 mb-8 print:hidden">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-0" id="toolbar-main">
          <div class="flex items-center gap-4">
            <button onclick="goToStep(5)" class="text-surface-500 p-3 hover:bg-surface-100 rounded transition-colors" title="Înapoi">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 18-6-6 6-6" /></svg>
            </button>
            <div>
              <h3 class="font-bold text-primary-900">Proiect Finalizat</h3>
              <p class="text-sm text-surface-500">Documentația vizuală este pregătită.</p>
            </div>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <!-- SVG Pack Download -->
            <button onclick="downloadSVGPack()" class="bg-indigo-600 text-white px-5 py-3 text-sm rounded flex items-center gap-2 hover:bg-indigo-700 transition-all shadow-md font-medium">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Pachet SVG (.zip)
            </button>
            <!-- Real PDF Download -->
            <button id="btn-download-pdf" onclick="generateRealPDF()" class="bg-green-600 text-white px-5 py-3 text-sm rounded flex items-center gap-2 hover:bg-green-700 transition-all shadow-md font-medium">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              Descarcă PDF
            </button>
            <!-- Print fallback -->
            <button onclick="downloadPDF()" class="btn-outline px-5 py-3 text-sm rounded flex items-center gap-2">
