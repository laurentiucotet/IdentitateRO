    // ===== GENERATE REAL PDF (html2canvas + jsPDF) =====
    async function generateRealPDF() {
      const btn = /** @type {HTMLButtonElement} */ ($('#btn-download-pdf'));
      const progressContainer = $('#pdf-progress-container');
      const progressFill = $('#pdf-progress-fill');
      const progressLabel = $('#pdf-progress-label');
      const progressPercent = $('#pdf-progress-percent');
      
      if (btn) btn.disabled = true;
      if (progressContainer) progressContainer.classList.remove('hidden');
      
      const setProgress = (/** @type {number} */ pct, /** @type {string} */ label) => {
        if (progressFill) progressFill.style.width = `${pct}%`;
        if (progressPercent) progressPercent.textContent = `${Math.round(pct)}%`;
        if (progressLabel) progressLabel.textContent = label;
      };

      try {
        setProgress(5, 'Se inițializează...');
        
        // @ts-ignore
        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        
        const pages = /** @type {NodeListOf<HTMLElement>} */ (document.querySelectorAll('#pdf-content .pdf-page'));
        const totalPages = pages.length;
        
        for (let i = 0; i < totalPages; i++) {
          const page = pages[i];
          setProgress(10 + (i / totalPages) * 80, `Se renderizează pagina ${i + 1} din ${totalPages}...`);
          
          // Wait a tick for UI update
          await new Promise(r => setTimeout(r, 50));
          
          // @ts-ignore
          const canvas = await html2canvas(page, {
            scale: 2,
            useCORS: true,
            allowTaint: true,
            backgroundColor: null,
            logging: false,
            width: page.scrollWidth,
            height: page.scrollHeight,
          });
          
          const imgData = canvas.toDataURL('image/jpeg', 0.95);
          const pdfWidth = 210; // A4 width in mm
          const pdfHeight = 297; // A4 height in mm
          
          if (i > 0) pdf.addPage();
          pdf.addImage(imgData, 'JPEG', 0, 0, pdfWidth, pdfHeight);
        }
        
        setProgress(95, 'Se finalizează fișierul...');
        await new Promise(r => setTimeout(r, 100));
        
        const slug = state.brandName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
        const filename = `manual-identitate-${slug || 'vizuala'}.pdf`;
        
        pdf.save(filename);
        setProgress(100, 'Descărcare completă!');
        
        setTimeout(() => {
          if (progressContainer) progressContainer.classList.add('hidden');
          if (progressFill) progressFill.style.width = '0%';
        }, 2000);
        
      } catch (err) {
        console.error('PDF generation error:', err);
        setProgress(0, 'Eroare la generare. Încercați varianta Tipărește.');
        setTimeout(() => {
          if (progressContainer) progressContainer.classList.add('hidden');
        }, 4000);
      } finally {
        if (btn) btn.disabled = false;
      }
    }
    // @ts-ignore
    window.generateRealPDF = generateRealPDF;

    // ===== BUILD COMPOSITE SVG (symbol + text in a single SVG) =====
    function buildCompositeLogoSVG(theme, orientation) {
      const symbolSvg = theme === 'light' ? state.symbols.light : state.symbols.dark;
      const textColor = theme === 'light' ? '#0F172A' : '#FFFFFF';
      const lines = splitInstitutionName(state.brandName);
      const sz = state.safeZone;
      
      // Parse original SVG to extract viewBox and content
      const parser = new DOMParser();
      const svgDoc = parser.parseFromString(symbolSvg, 'image/svg+xml');
      const origSvg = svgDoc.querySelector('svg');
      if (!origSvg) return symbolSvg;
      
      const vb = origSvg.getAttribute('viewBox') || '0 0 100 100';
      const [, , vbW, vbH] = vb.split(/[\s,]+/).map(Number);
      const symbolContent = origSvg.innerHTML;
      
      // Symbol-only variant
      if (orientation === 'symbol') {
        return symbolSvg;
      }
      
      const symbolSize = 100;
      const gap = symbolSize * sz;
      const fontSize1 = 22;
      const fontSize2 = 18;
      const lineGap = 6;
      
      if (orientation === 'horizontal') {
        // Calculate approximate text width
        const maxTextLen = Math.max(...lines.map(l => l.length));
        const textBlockWidth = maxTextLen * fontSize1 * 0.6;
        const totalW = symbolSize + gap + textBlockWidth + 20;
        const totalH = Math.max(symbolSize, lines.length * (fontSize1 + lineGap) + 20);
        const symbolY = (totalH - symbolSize) / 2;
        const textX = symbolSize + gap;
        const textStartY = totalH / 2 - ((lines.length - 1) * (fontSize1 + lineGap)) / 2;
        
        let textElements = lines.map((line, idx) => {
          const fs = idx === 0 ? fontSize1 : fontSize2;
          const y = textStartY + idx * (fontSize1 + lineGap);
          return `<text x="${textX}" y="${y}" font-family="${state.fonts.primary}, serif" font-size="${fs}" font-weight="700" fill="${textColor}" letter-spacing="1" dominant-baseline="middle">${escapeXml(line)}</text>`;
        }).join('\n      ');
        
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${totalW} ${totalH}" width="${totalW}" height="${totalH}">
      <svg x="0" y="${symbolY}" width="${symbolSize}" height="${symbolSize}" viewBox="${vb}">${symbolContent}</svg>
      ${textElements}
    </svg>`;
      }
      
      // vertical
      const maxTextLen = Math.max(...lines.map(l => l.length));
      const textBlockWidth = maxTextLen * fontSize1 * 0.65;
      const totalW = Math.max(symbolSize, textBlockWidth) + 40;
      const textBlockH = lines.length * (fontSize1 + lineGap);
      const totalH = symbolSize + gap + textBlockH + 20;
      const symbolX = (totalW - symbolSize) / 2;
      const textStartY = symbolSize + gap + fontSize1;
      
      let textElements = lines.map((line, idx) => {
        const fs = idx === 0 ? fontSize1 : fontSize2;
        const y = textStartY + idx * (fontSize1 + lineGap);
        return `<text x="${totalW / 2}" y="${y}" font-family="${state.fonts.primary}, serif" font-size="${fs}" font-weight="700" fill="${textColor}" text-anchor="middle" letter-spacing="1">${escapeXml(line)}</text>`;
      }).join('\n      ');
      
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${totalW} ${totalH}" width="${totalW}" height="${totalH}">
      <svg x="${symbolX}" y="0" width="${symbolSize}" height="${symbolSize}" viewBox="${vb}">${symbolContent}</svg>
      ${textElements}
    </svg>`;
    }
    
    function escapeXml(str) {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&apos;');
    }

    // ===== DOWNLOAD SVG PACK AS ZIP =====
    async function downloadSVGPack() {
      // @ts-ignore
      const zip = new JSZip();
      const slug = state.brandName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'identitate';
      
      const folderName = `identitate-vizuala-${slug}`;
      const root = zip.folder(folderName);
      
      // Raw symbols
      const symbolsFolder = root.folder('simboluri');
      if (state.symbols.light) {
        symbolsFolder.file('simbol-fundal-deschis.svg', state.symbols.light);
      }
      if (state.symbols.dark) {
        symbolsFolder.file('simbol-fundal-inchis.svg', state.symbols.dark);
      }
      
      // Composite logos — light theme
      const lightFolder = root.folder('logo-fundal-deschis');
      lightFolder.file('orizontal.svg', buildCompositeLogoSVG('light', 'horizontal'));
      lightFolder.file('vertical.svg', buildCompositeLogoSVG('light', 'vertical'));
      lightFolder.file('simbol.svg', buildCompositeLogoSVG('light', 'symbol'));
      
      // Composite logos — dark theme
      const darkFolder = root.folder('logo-fundal-inchis');
      darkFolder.file('orizontal.svg', buildCompositeLogoSVG('dark', 'horizontal'));
      darkFolder.file('vertical.svg', buildCompositeLogoSVG('dark', 'vertical'));
      darkFolder.file('simbol.svg', buildCompositeLogoSVG('dark', 'symbol'));
      
      // Color palette info file
      const colorsInfo = state.colors.map(c => {
        const data = getColorData(c.hex);
        let line = `${c.name || 'Fără nume'}\n  HEX: ${data.hex}\n  RGB: ${data.rgb}\n  CMYK: ${data.cmyk}`;
        if (c.pantone) line += `\n  Pantone: ${c.pantone}`;
        return line;
      }).join('\n\n');
      
      root.file('paleta-culori.txt', `Paleta de Culori — ${state.brandName}\n${'='.repeat(50)}\n\n${colorsInfo}\n`);
      
      // Metadata / README
      const readmeContent = `# ${state.brandName}
## Pachet Identitate Vizuală

Generat automat de IdentitateRO Generator
Data: ${new Date().toLocaleDateString('ro-RO')}

### Structură Fișiere

- simboluri/ — SVG-urile originale ale simbolului
  - simbol-fundal-deschis.svg
  - simbol-fundal-inchis.svg
- logo-fundal-deschis/ — Logo-uri compuse pe fundal deschis
  - orizontal.svg
  - vertical.svg
  - simbol.svg
- logo-fundal-inchis/ — Logo-uri compuse pe fundal închis
  - orizontal.svg
  - vertical.svg
  - simbol.svg
- paleta-culori.txt — Valorile cromatice (HEX, RGB, CMYK, Pantone)

### Fonturi Utilizate

- Font Principal: ${state.fonts.primary}
- Font Secundar: ${state.fonts.secondary}

### Zonă de Protecție

Proporție: ${Math.round(state.safeZone * 100)}%
`;
      root.file('README.md', readmeContent);
      
      // Generate and download ZIP
      const content = await zip.generateAsync({ type: 'blob' });
      // @ts-ignore
      saveAs(content, `${folderName}.zip`);
    }
    // @ts-ignore
    window.downloadSVGPack = downloadSVGPack;

    // ===== INIT =====
    function init() {
      // File upload handlers
      setupUpload('light');
      setupUpload('dark');

      // Brand name input
      const nameInput = /** @type {HTMLInputElement} */ ($('#brand-name'));
      if (nameInput) {
        nameInput.addEventListener('input', (e) => {
          state.brandName = /** @type {HTMLInputElement} */ (e.target).value.toUpperCase();
          updateNamePreview();
        });
        updateNamePreview();
      }

      // Font inputs
      const fontPrimary = /** @type {HTMLInputElement} */ ($('#font-primary'));
      const fontSecondary = /** @type {HTMLInputElement} */ ($('#font-secondary'));
      if (fontPrimary) {
        fontPrimary.addEventListener('input', (e) => {
          state.fonts.primary = /** @type {HTMLInputElement} */ (e.target).value;
          renderTypographyPreview();
        });
      }
      if (fontSecondary) {
        fontSecondary.addEventListener('input', (e) => {
          state.fonts.secondary = /** @type {HTMLInputElement} */ (e.target).value;
          renderTypographyPreview();
        });
      }

      // Safe zone range
      const safeRange = /** @type {HTMLInputElement} */ ($('#safe-zone-range'));
      if (safeRange) {
        safeRange.addEventListener('input', (e) => {
          state.safeZone = parseFloat(/** @type {HTMLInputElement} */ (e.target).value);
          const label = $('#safe-zone-label');
          if (label) label.textContent = String(Math.round(state.safeZone * 100));
          renderPreviews();
        });
      }

      // Initial step
      goToStep(1);
    }

    function updateNamePreview() {
      const preview = $('#name-preview');
      if (!preview) return;
      const lines = splitInstitutionName(state.brandName);
      preview.innerHTML = lines.map(line => `<span>${line}</span>`).join('');
    }

    // Run on DOM ready
    document.addEventListener('DOMContentLoaded', init);
    if (document.readyState !== 'loading') init();
  </script>
</BaseLayout>
