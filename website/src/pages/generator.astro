        <!-- PDF Page 7: Usage Rules (Do / Don't) -->
        <div class="pdf-page p-20 min-h-[297mm] bg-white flex flex-col justify-center">
          <h2 id="pdf-p7-title" class="text-4xl font-bold mb-10 text-primary-900 uppercase tracking-wide">Reguli de Utilizare</h2>
          <p id="pdf-p7-desc" class="text-lg text-surface-600 mb-16 max-w-3xl leading-relaxed">Garantarea consistenței vizuale solicită respectarea unor principii stricte. Prezentăm modalitățile corecte și cele incorecte de utilizare.</p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <!-- Correct -->
            <div class="bg-surface-50 p-10 rounded border border-green-200 shadow-card flex flex-col items-center text-center">
              <div class="text-green-600 mb-8 flex flex-col items-center">
                <svg class="w-10 h-10 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="font-bold text-lg uppercase tracking-wide">Utilizare Corectă</span>
