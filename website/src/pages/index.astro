---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoCard from '../components/LogoCard.astro';
import institutionIndex from '../data/institutions-index.json';
import { getPrimaryLogoPath, hasSvg } from '../lib/helpers';
import { CATEGORY_LABELS, CATEGORY_ORDER } from '../lib/labels';
import type { Institution } from '../types/institution';

const institutions = institutionIndex.institutions as unknown as Institution[];

// Grupare pe categorii cu ordine prestabilită
const grouped = new Map<string, typeof institutions>();
for (const cat of CATEGORY_ORDER) {
  const items = institutions.filter((i) => i.category === cat);
  if (items.length > 0) grouped.set(cat, items);
}

// Categoriile active (cele care au cel puțin o instituție)
const activeCategories = [...grouped.keys()];

// Build category labels map for JS
const categoryLabelsJson = JSON.stringify(CATEGORY_LABELS);
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary-50/50 to-surface-50 -z-10"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8 text-center">
      <!-- Beta badge -->
      <div
        class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded bg-primary-50 border border-primary-100 mb-4"
      >
        <span class="text-[11px] font-medium text-primary-700"
          >Versiune Beta &middot; Proiect Civic</span
        >
      </div>

      <!-- Title -->
      <h1
        class="text-2xl sm:text-3xl lg:text-4xl font-bold text-primary-900 leading-tight text-balance mb-4"
      >
        Identitatea Vizuală<br />a României, <span class="text-primary-500">centralizată.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-sm sm:text-base text-surface-500 max-w-xl mx-auto mb-8 text-balance">
        Registru cu siglele instituțiilor publice in format vectorial.
      </p>

      <!-- Search Input -->
      <div class="relative max-w-xl mx-auto" id="search-wrapper">
        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
          <svg
            class="w-5 h-5 text-surface-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <input
          type="search"
          id="search-input"
          class="search-input pl-12 pr-12"
          placeholder="Caută instituții..."
          data-placeholder-long={'Caută „Consiliul Judențean Timiș", „Ministerul Educației"...'}
          data-placeholder-short="Caută instituții..."
          autocomplete="off"
        />
        <!-- Keyboard shortcut hint — hidden on mobile (no physical keyboard) -->
        <div
          class="absolute inset-y-0 right-0 pr-4 hidden md:flex items-center pointer-events-none"
          id="search-shortcut"
        >
          <kbd
            class="px-1.5 py-0.5 bg-surface-100 border border-surface-200 rounded text-[11px] text-surface-400 font-mono"
            >/</kbd
          >
        </div>
        <div id="search-hint" class="mt-2 text-xs text-surface-400 hidden">
          <span class="hidden md:inline"
            ><kbd class="px-1.5 py-0.5 bg-surface-100 rounded text-surface-500 font-mono">ESC</kbd> pentru
            a reseta</span
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Bar — sticky on md+, scrolls away on mobile -->
  <section
    class="md:sticky md:top-12 z-30 bg-white/80 backdrop-blur-md border-b border-surface-200"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <!-- Overflow container with gradient hint -->
      <div class="relative">
        <div
          class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-hide"
          id="filter-bar"
          role="tablist"
          aria-label="Filtrare după categorie"
        >
          <button class="category-chip category-chip--active shrink-0" data-category="all">
            Toate ({institutions.length})
          </button>
          {
            activeCategories.map((cat) => (
              <button class="category-chip category-chip--inactive shrink-0" data-category={cat}>
                {CATEGORY_LABELS[cat] || cat} ({grouped.get(cat)?.length || 0})
              </button>
            ))
          }
        </div>
        <!-- Right gradient overlay to signal more chips -->
        <div
          class="pointer-events-none absolute inset-y-0 right-0 w-8 bg-gradient-to-l from-white/90 to-transparent md:hidden"
          id="filter-gradient"
        >
        </div>
      </div>
    </div>
  </section>

  <!-- Active Filters Summary — removed: duplicates the filter chips bar above -->

  <!-- Logo Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Results info -->
    <div class="flex items-center justify-between mb-4">
      <p id="results-count" class="text-xs text-surface-500">
        {institutions.length} instituții disponibile
      </p>
      <div class="text-xs text-surface-400 hidden sm:block">
        Apasă pe un card pentru detalii și download
      </div>
    </div>

    <!-- Single DOM: Category Sections (cards are shown/hidden in-place) -->
    <div id="category-sections">
      {
        [...grouped.entries()].map(([cat, items]) => (
          <div class="category-section mb-8" data-category-section={cat}>
            <h2 class="category-heading text-lg font-semibold text-primary-900 mb-3">
              {CATEGORY_LABELS[cat] || cat}
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4">
              {items.map((inst) => {
                const logoPath = getPrimaryLogoPath(inst) || '';
                const hasSvgFlag = hasSvg(inst);
                return (
                  <LogoCard
                    slug={inst.slug}
                    name={inst.name}
                    shortname={inst.shortname}
                    category={inst.category}
                    logoPath={logoPath}
                    hasSvg={hasSvgFlag}
                    keywords={inst.meta.keywords}
                  />
                );
              })}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Empty state (dynamic content set via JS) -->
    <div id="empty-state" class="hidden py-20 text-center">
      <svg
        class="w-16 h-16 mx-auto mb-4 text-surface-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
      <h3 class="text-sm font-semibold text-primary-900 mb-2" id="empty-title">Niciun rezultat</h3>
      <p class="text-surface-500 text-xs mb-4" id="empty-message">
        Nu am găsit nicio instituție care să corespundă căutării tale.
      </p>
      <div id="empty-actions" class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <button type="button" id="empty-search-all" class="btn-secondary hidden"
          >Caută în toate categoriile</button
        >
        <a href="/solicita" class="btn-primary">Solicită adăugarea</a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Inline JSON data for client-side search & filter -->
<script define:vars={{ institutions: institutionIndex.institutions, categoryLabelsJson }}>
  window.__IDENTITATE_DATA__ = institutions;
  window.__CATEGORY_LABELS__ = JSON.parse(categoryLabelsJson);
</script>

<script>
  /**
   * IdentitateRO — Client-side interactivity (v4.0 — Mobile-first rewrite)
   * Single DOM, active filter pills, URL persistence, smart empty state
   */
  import Fuse from 'fuse.js';

  document.addEventListener('DOMContentLoaded', () => {
    const data = window.__IDENTITATE_DATA__;
    const LABELS: Record<string, string> = window.__CATEGORY_LABELS__;

    // Initialize Fuse.js for fuzzy search
    const fuse = new Fuse(data, {
      keys: [
        { name: 'name', weight: 0.4 },
        { name: 'shortname', weight: 0.3 },
        { name: 'meta.keywords', weight: 0.2 },
        { name: 'description', weight: 0.1 },
      ],
      threshold: 0.35,
      ignoreLocation: true,
      useExtendedSearch: false,
    });

    // DOM elements
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchShortcut = document.getElementById('search-shortcut')!;
    const filterBar = document.getElementById('filter-bar')!;
    const categorySections = document.getElementById('category-sections')!;
    const emptyState = document.getElementById('empty-state')!;
    const resultsCount = document.getElementById('results-count')!;
    const filterGradient = document.getElementById('filter-gradient');

    // Empty state elements
    const emptyTitle = document.getElementById('empty-title')!;
    const emptyMessage = document.getElementById('empty-message')!;
    const emptySearchAll = document.getElementById('empty-search-all')!;

    // Responsive placeholder
    function updatePlaceholder() {
      const isWide = window.innerWidth >= 640;
      searchInput.placeholder = isWide
        ? searchInput.dataset.placeholderLong || searchInput.placeholder
        : searchInput.dataset.placeholderShort || searchInput.placeholder;
    }
    updatePlaceholder();
    window.addEventListener('resize', updatePlaceholder);

    // Hide / shortcut indicator when input is focused
    searchInput.addEventListener('focus', () => searchShortcut.classList.add('hidden'));
    searchInput.addEventListener('blur', () => {
      if (!searchInput.value) searchShortcut.classList.remove('hidden');
    });

    // State
    let activeCategory = 'all';
    let searchQuery = '';

    // ── URL State ───────────────────────────────────────────────────────
    function readUrlState() {
      const params = new URLSearchParams(window.location.search);
      const cat = params.get('categorie') || params.get('cat');
      const q = params.get('q');
      if (cat && cat !== 'all') activeCategory = cat;
      if (q) {
        searchQuery = q;
        searchInput.value = q;
      }
    }

    function writeUrlState() {
      const params = new URLSearchParams();
      if (activeCategory !== 'all') params.set('categorie', activeCategory);
      if (searchQuery.trim()) params.set('q', searchQuery.trim());
      const qs = params.toString();
      const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
      history.replaceState(null, '', url);
    }

    // ── Core filter/search ─────────────────────────────────────────────
    function filterAndSearch() {
      const query = searchQuery.toLowerCase().trim();

      // Get matching slugs from search
      const matchingSlugs = query ? new Set(fuse.search(query).map((r) => r.item.slug)) : null;

      let totalVisible = 0;

      // Iterate over each category section
      categorySections
        .querySelectorAll<HTMLElement>('[data-category-section]')
        .forEach((section) => {
          const sectionCat = section.dataset.categorySection!;
          const cards = section.querySelectorAll<HTMLElement>('[data-institution-id]');
          const heading = section.querySelector('.category-heading') as HTMLElement;

          // If a specific category is selected and this isn't it, hide entire section
          if (activeCategory !== 'all' && sectionCat !== activeCategory) {
            section.classList.add('hidden');
            return;
          }

          let sectionVisible = 0;

          cards.forEach((card) => {
            const slug = card.dataset.institutionId!;
            const matchesSearch = !query || (matchingSlugs && matchingSlugs.has(slug));

            if (matchesSearch) {
              card.classList.remove('hidden');
              sectionVisible++;
            } else {
              card.classList.add('hidden');
            }
          });

          // Hide section if no visible cards, show otherwise
          section.classList.toggle('hidden', sectionVisible === 0);

          // Hide category headings when a specific category is selected (no need to show heading for only one category)
          if (heading) {
            heading.classList.toggle('hidden', activeCategory !== 'all');
          }

          totalVisible += sectionVisible;
        });

      // Update UI counts
      resultsCount.textContent = `${totalVisible} ${totalVisible === 1 ? 'instituție disponibilă' : 'instituții disponibile'}`;

      // Empty state
      if (totalVisible === 0) {
        emptyState.classList.remove('hidden');
        categorySections.classList.add('hidden');

        // Smart empty state message
        const hasCategory = activeCategory !== 'all';
        const catLabel = LABELS[activeCategory] || activeCategory;
        if (hasCategory && query) {
          emptyTitle.textContent = 'Niciun rezultat';
          emptyMessage.textContent = `Nu am găsit „${searchQuery.trim()}" în categoria ${catLabel}.`;
          emptySearchAll.classList.remove('hidden');
          emptySearchAll.textContent = 'Caută în toate categoriile';
        } else if (query) {
          emptyTitle.textContent = 'Niciun rezultat';
          emptyMessage.textContent = `Nu am găsit nicio instituție pentru „${searchQuery.trim()}".`;
          emptySearchAll.classList.add('hidden');
        } else {
          emptyTitle.textContent = 'Niciun rezultat';
          emptyMessage.textContent =
            'Nu am găsit nicio instituție care să corespundă căutării tale.';
          emptySearchAll.classList.add('hidden');
        }
      } else {
        emptyState.classList.add('hidden');
        categorySections.classList.remove('hidden');
      }

      // Update filter pills and URL
      writeUrlState();

      // Update filter bar active chip
      filterBar.querySelectorAll<HTMLElement>('[data-category]').forEach((chip) => {
        if (chip.dataset.category === activeCategory) {
          chip.classList.remove('category-chip--inactive');
          chip.classList.add('category-chip--active');
        } else {
          chip.classList.remove('category-chip--active');
          chip.classList.add('category-chip--inactive');
        }
      });
    }

    // ── Event listeners ────────────────────────────────────────────────

    // Search input
    searchInput.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value;
      searchShortcut.classList.toggle('hidden', !!searchQuery);
      filterAndSearch();
    });

    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        searchQuery = '';
        activeCategory = 'all';
        filterAndSearch();
        searchInput.blur();
      }
    });

    // Category filter buttons
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-category]') as HTMLElement;
      if (!btn) return;
      activeCategory = btn.dataset.category!;
      filterAndSearch();
    });

    // "Search in all categories" from empty state
    emptySearchAll.addEventListener('click', () => {
      activeCategory = 'all';
      filterAndSearch();
    });

    // Keyboard shortcut: focus search with /
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput.focus();
      }
    });

    // Filter bar gradient visibility (hide when scrolled to end)
    if (filterGradient) {
      const filterScroll = filterBar;
      function checkGradient() {
        if (!filterScroll) return;
        const atEnd =
          filterScroll.scrollLeft + filterScroll.clientWidth >= filterScroll.scrollWidth - 4;
        filterGradient!.classList.toggle('hidden', atEnd);
      }
      filterScroll.addEventListener('scroll', checkGradient, { passive: true });
      checkGradient();
    }

    // Read initial state from URL and apply
    readUrlState();
    filterAndSearch();
  });
</script>
