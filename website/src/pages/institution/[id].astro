---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorSwatch from '../../components/ColorSwatch.astro';
import LogoVariantCard from '../../components/LogoVariantCard.astro';
import institutionIndex from '../../data/institutions-index.json';
import {
  getAllDownloadableAssets,
  getPrimaryLogoPath,
  getLogoVariants,
  getCdnLogoUrl,
} from '../../lib/helpers';
import { resolveAssetPath } from '../../lib/cdn-helpers';
import { CATEGORY_LABELS_SINGULAR, LOGO_LAYOUT_LABELS, QUALITY_LABELS } from '../../lib/labels';

import type { Institution, LogoLayout, Color } from '../../types/institution';

export async function getStaticPaths() {
  return institutionIndex.institutions.map((inst) => ({
    params: { id: inst.slug },
    props: { institution: inst as unknown as Institution },
  }));
}

const { institution: inst } = Astro.props;

const primaryLogo = getPrimaryLogoPath(inst);
const downloadables = getAllDownloadableAssets(inst);

// ── SEO ────────────────────────────────────────────────────────────────
const siteUrl = Astro.site?.origin || 'https://identitate.eu';
const canonicalUrl = `${siteUrl}/institution/${inst.slug}`;
const absoluteLogo = primaryLogo ? `${siteUrl}${primaryLogo}` : undefined;

// Dynamic, keyword-rich title & description (overrideable from JSON)
const descParts: string[] = [];
descParts.push(`Descarcă logo-uri oficiale pentru ${inst.name}`);
if (inst.shortname) descParts.push(`(${inst.shortname.toUpperCase()})`);
descParts.push('în format SVG și PNG.');
if (inst.colors && inst.colors.length > 0)
  descParts.push(`Paletă de ${inst.colors.length} culori oficiale.`);
if (inst.typography?.primary) descParts.push(`Font: ${inst.typography.primary.family}.`);
descParts.push('Gratuit, open-source.');

const title = inst.meta.seo_title || `${inst.name} — Logo și Identitate Vizuală | IdentitateRO`;
const description = inst.meta.seo_description || descParts.join(' ');

// JSON-LD: GovernmentOrganization
const sameAsLinks: string[] = [];
if (inst.resources?.website) sameAsLinks.push(inst.resources.website);
if (inst.resources?.wikipedia_url) sameAsLinks.push(inst.resources.wikipedia_url);
if (inst.resources?.social_media) {
  Object.values(inst.resources.social_media).forEach((url) => {
    if (url) sameAsLinks.push(url);
  });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'GovernmentOrganization',
  name: inst.name,
  ...(inst.shortname && { alternateName: inst.shortname.toUpperCase() }),
  url: inst.resources?.website || canonicalUrl,
  ...(absoluteLogo && { logo: absoluteLogo, image: absoluteLogo }),
  ...(inst.description && { description: inst.description }),
  ...(inst.location && {
    address: {
      '@type': 'PostalAddress',
      ...(inst.location.city && { addressLocality: inst.location.city }),
      ...(inst.location.county && { addressRegion: inst.location.county }),
      addressCountry: inst.location.country_code || 'RO',
    },
  }),
  ...(sameAsLinks.length > 0 && { sameAs: sameAsLinks }),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Acasă', item: siteUrl },
    {
      '@type': 'ListItem',
      position: 2,
      name: CATEGORY_LABELS_SINGULAR[inst.category] || inst.category,
      item: `${siteUrl}/?categorie=${inst.category}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: inst.shortname?.toUpperCase() || inst.name,
      item: canonicalUrl,
    },
  ],
};

// ── Page data ──────────────────────────────────────────────────────────
const logoLayouts: Array<{ key: string; layout: LogoLayout }> = [
  { key: 'horizontal', layout: 'horizontal' },
  { key: 'vertical', layout: 'vertical' },
  { key: 'symbol', layout: 'symbol' },
];
const qualityInfo = inst.meta.quality ? QUALITY_LABELS[inst.meta.quality] : undefined;

// Compute CDN path dynamically with fallback
const cdnLogoPath = getCdnLogoUrl(inst) ?? undefined;
---

<BaseLayout title={title} description={description} ogImage={absoluteLogo} ogType="website">
  {/* JSON-LD structured data */}
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbLd)}
    slot="head"
  />

  <article
    class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12"
    itemscope
    itemtype="https://schema.org/GovernmentOrganization"
  >
    <!-- Header -->
    <header class="mb-10">
      {/* Breadcrumb navigation */}
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-surface-400">
          <li><a href="/" class="text-primary-500 hover:text-primary-600">Acasă</a></li>
          <li aria-hidden="true">&rsaquo;</li>
          <li>
            <a href={`/?categorie=${inst.category}`} class="text-primary-500 hover:text-primary-600"
              >{CATEGORY_LABELS_SINGULAR[inst.category] || inst.category}</a>
          </li>
          <li aria-hidden="true">&rsaquo;</li>
          <li aria-current="page" class="text-surface-600 font-medium">
            {inst.shortname?.toUpperCase() || inst.name}
          </li>
        </ol>
      </nav>

      <div class="flex flex-wrap items-start gap-4">
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl sm:text-3xl font-bold text-primary-900 mb-2" itemprop="name">
            {inst.name}
          </h1>

          <div class="flex flex-wrap items-center gap-2 mb-3">
            {
              inst.shortname && (
                <span class="px-2 py-0.5 bg-primary-100 text-primary-700 rounded text-xs font-semibold">
                  {inst.shortname.toUpperCase()}
                </span>
              )
            }
            <span class="px-2 py-0.5 bg-surface-100 text-surface-600 rounded text-xs">
              {CATEGORY_LABELS_SINGULAR[inst.category] || inst.category}
            </span>
            {
              inst.meta?.quality === 'verified' && (
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-green-50 text-green-700 border border-green-200 rounded text-xs font-medium">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Confirmat oficial
                </span>
              )
            }
            {
              inst.meta?.quality === 'official_source' && (
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-blue-50 text-blue-700 border border-blue-200 rounded text-xs font-medium">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zm-1-5a1 1 0 112 0v1a1 1 0 11-2 0v-1zm1-9a1 1 0 00-1 1v4a1 1 0 102 0V5a1 1 0 00-1-1z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Din surse oficiale
                </span>
              )
            }
            {
              (!inst.meta?.quality || inst.meta?.quality === 'unverified') && (
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-50 text-amber-700 border border-amber-200 rounded text-xs font-medium">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Neconfirmat oficial
                </span>
              )
            }
          </div>

          {
            inst.description && (
              <p class="text-sm text-surface-500 mb-2" itemprop="description">
                {inst.description}
              </p>
            )
          }

          {
            inst.location && (
              <p class="text-xs text-surface-400 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                  />
                </svg>
                {[inst.location.city, inst.location.county].filter(Boolean).join(', ')}
              </p>
            )
          }

          {
            inst.usage_notes && (
              <div class="mt-3 p-3 bg-amber-50 border border-amber-200 rounded text-xs text-amber-800">
                <strong>Note de utilizare:</strong> {inst.usage_notes}
              </div>
            )
          }
        </div>

        {/* Mini preview în header */}
        {
          primaryLogo && (
            <div class="shrink-0 w-20 h-20 sm:w-24 sm:h-24 bg-white border border-surface-200 rounded p-3 flex items-center justify-center">
              <img
                src={primaryLogo}
                alt={`Logo ${inst.name}`}
                class="max-w-full max-h-full object-contain"
                itemprop="logo"
                loading="eager"
                width="96"
                height="96"
              />
            </div>
          )
        }
      </div>

      {/* Keywords */}
      {
        inst.meta.keywords && inst.meta.keywords.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-4">
            {inst.meta.keywords.map((keyword: string) => (
              <span class="px-2 py-1 bg-surface-50 border border-surface-200 rounded-full text-[11px] text-surface-500">
                {keyword}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <!-- ═══ LOGO-URI ═══ -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path>
        </svg>
        Logo-uri
      </h2>

      {
        logoLayouts.map(({ key, layout }) => {
          const group = inst.assets[layout];
          if (!group) return null;

          const layoutLabel = LOGO_LAYOUT_LABELS[key] || key;
          const variants = getLogoVariants(group);

          return (
            <div class="mb-6">
              <h3 class="text-sm font-medium text-primary-800 mb-3">{layoutLabel}</h3>

              {/* Preview-uri variante */}
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-3">
                {variants.map(([variant, path]) => (
                  <LogoVariantCard
                    variant={variant}
                    path={path}
                    layoutLabel={layoutLabel}
                    institutionName={inst.name}
                  />
                ))}

                {/* PNG variant */}
                {group.png &&
                  (() => {
                    const pngPath = resolveAssetPath(group.png.path, true);
                    if (!pngPath) return null;
                    return (
                      <div class="border border-surface-200 rounded overflow-hidden hover:shadow-md hover:border-surface-300 transition-all duration-200">
                        <div class="checkerboard aspect-[3/2] flex items-center justify-center p-6">
                          <img
                            src={pngPath}
                            alt={`Logo ${inst.name} — ${layoutLabel} PNG`}
                            class="max-w-full max-h-full object-contain"
                            loading="lazy"
                            decoding="async"
                          />
                        </div>
                        <div class="p-2 bg-white flex items-center justify-between">
                          <div>
                            <span class="text-xs font-medium text-primary-900">PNG</span>
                            <span class="text-[11px] text-surface-400 ml-1">
                              {group.png.width} × {group.png.height}px
                            </span>
                          </div>
                          <a
                            href={pngPath}
                            download
                            class="p-2 rounded hover:bg-primary-50 text-surface-400 hover:text-primary-500 transition-colors"
                            title="Descarcă PNG"
                          >
                            <svg
                              class="w-4 h-4"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                              />
                            </svg>
                          </a>
                        </div>
                      </div>
                    );
                  })()}
              </div>
            </div>
          );
        })
      }
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- ═══ CULORI OFICIALE ═══ -->
      {
        inst.colors && inst.colors.length > 0 && (
          <section>
            <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
              <svg
                class="w-5 h-5 text-primary-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
                />
              </svg>
              Paletă de Culori
            </h2>
            <div class="space-y-3">
              {inst.colors.map((color: Color) => (
                <ColorSwatch color={color} />
              ))}
            </div>
          </section>
        )
      }

      <!-- ═══ TIPOGRAFIE + RESURSE ═══ -->
      <div class="space-y-8">
        {/* Tipografie */}
        {
          inst.typography && inst.typography.primary && (
            <section>
              <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
                <svg
                  class="w-5 h-5 text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h8m-8 6h16"
                  />
                </svg>
                Tipografie
              </h2>
              <div class="space-y-2">
                <div class="bg-white border border-surface-200 rounded p-3 flex items-center justify-between">
                  <div>
                    <div class="font-medium text-sm text-primary-900">
                      {inst.typography.primary.family}
                    </div>
                    <div class="text-xs text-surface-500">Font principal</div>
                  </div>
                  {inst.typography.primary.url && (
                    <a
                      href={inst.typography.primary.url}
                      target="_blank"
                      rel="noopener"
                      class="text-xs text-primary-500 hover:text-primary-600"
                    >
                      Vezi font &rarr;
                    </a>
                  )}
                </div>
                {inst.typography.secondary && (
                  <div class="bg-white border border-surface-200 rounded p-3 flex items-center justify-between">
                    <div>
                      <div class="font-medium text-sm text-primary-900">
                        {inst.typography.secondary.family}
                      </div>
                      <div class="text-xs text-surface-500">Font secundar</div>
                    </div>
                    {inst.typography.secondary.url && (
                      <a
                        href={inst.typography.secondary.url}
                        target="_blank"
                        rel="noopener"
                        class="text-xs text-primary-500 hover:text-primary-600"
                      >
                        Vezi font &rarr;
                      </a>
                    )}
                  </div>
                )}
              </div>
            </section>
          )
        }
      </div>
    </div>

    <!-- ═══ DESCĂRCĂRI RAPIDE ═══ -->
    {
      downloadables.length > 0 && (
        <section class="mt-10">
          <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
            <svg
              class="w-5 h-5 text-primary-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              />
            </svg>
            Toate Descărcările
          </h2>
          <button
            id="download-zip"
            data-downloadables={JSON.stringify(downloadables)}
            data-slug={inst.slug}
            class="mb-4 px-4 py-2 bg-primary-500 text-white rounded hover:bg-primary-600 transition-colors flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              />
            </svg>
            Descarcă toate ca ZIP
          </button>
        </section>
      )
    }

    <!-- ═══ INTEGRARE (tabs) ═══ -->
    <section class="mt-10">
      <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
        </svg>
        Integrare
      </h2>
      <!-- Tab buttons -->
      <div class="flex border-b border-surface-200">
        <button
          type="button"
          data-tab-btn="cdn"
          class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-primary-500 text-primary-700 -mb-px"
          >CDN</button
        >
        <button
          type="button"
          data-tab-btn="npm"
          class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-surface-500 hover:text-surface-700 -mb-px"
          >NPM</button
        >
        <button
          type="button"
          data-tab-btn="direct"
          class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-surface-500 hover:text-surface-700 -mb-px"
          >URL Direct</button
        >
      </div>
      <!-- Tab panels -->
      <div class="bg-white border border-t-0 border-surface-200 rounded-b-lg p-4">
        <!-- CDN Panel -->
        <div data-tab-panel="cdn" class="tab-panel">
          <p class="text-sm text-surface-600 mb-3">Include logo-ul direct în HTML:</p>
          <div class="relative bg-gray-50 p-3 rounded font-mono text-sm overflow-x-auto border">
            <span class="text-pink-600">&lt;img</span>
            <span class="text-blue-600">src</span>=<span class="text-green-600"
              >"{cdnLogoPath}"</span
            >
            <span class="text-blue-600">alt</span>=<span class="text-green-600">"{inst.name}"</span
            ><span class="text-pink-600">&gt;</span>
            <button
              type="button"
              class="copy-code-btn absolute top-2 right-2 p-2 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors"
              data-value={`<img src="${cdnLogoPath}" alt="${inst.name}">`}
              title="Copiază"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                ></path></svg
              >
            </button>
          </div>
        </div>
        <!-- NPM Panel -->
        <div data-tab-panel="npm" class="tab-panel hidden">
          <p class="text-sm text-surface-600 mb-3">Instalează pachetul și importă datele:</p>
          <div class="space-y-2">
            <div class="relative bg-gray-50 p-3 rounded font-mono text-sm border">
              <span class="text-surface-500">$</span> npm install @identitate-ro/logos
              <button
                type="button"
                class="copy-code-btn absolute top-2 right-2 p-2 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors"
                data-value="npm install @identitate-ro/logos"
                title="Copiază"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                  ></path></svg
                >
              </button>
            </div>
            <div class="relative bg-gray-50 p-3 rounded font-mono text-sm border overflow-x-auto">
              <span class="text-pink-600">import</span> logos <span class="text-pink-600">from</span
              >
              <span class="text-green-600">'@identitate-ro/logos'</span>;<br />
              <span class="text-pink-600">const</span> logo = logos.institutions.<span
                class="text-blue-600">find</span
              >(i =&gt; i.id === <span class="text-green-600">'{inst.id}'</span>);
              <button
                type="button"
                class="copy-code-btn absolute top-2 right-2 p-2 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors"
                data-value={`import logos from '@identitate-ro/logos';\nconst logo = logos.institutions.find(i => i.id === '${inst.id}');`}
                title="Copiază"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                  ></path></svg
                >
              </button>
            </div>
          </div>
        </div>
        <!-- URL Direct Panel -->
