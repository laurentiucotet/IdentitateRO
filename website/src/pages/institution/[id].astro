---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorSwatch from '../../components/ColorSwatch.astro';
import LogoVariantCard from '../../components/LogoVariantCard.astro';
import institutionIndex from '../../data/institutions-index.json';
import { getAllDownloadableAssets, getPrimaryLogoPath, getLogoVariants, getCdnLogoUrl } from '../../lib/helpers';
import { resolveAssetPath } from '../../lib/cdn-helpers';
import {
  CATEGORY_LABELS_SINGULAR,
  LOGO_LAYOUT_LABELS,
  LOGO_VARIANT_LABELS,
  COLOR_USAGE_LABELS,
  QUALITY_LABELS,
} from '../../lib/labels';

import type { Institution, LogoLayout, Color } from '../../types/institution';

export async function getStaticPaths() {
  return (institutionIndex.institutions).map(inst => ({
    params: { id: inst.slug },
    props: { institution: inst as unknown as Institution }
  }));
}

const { institution: inst } = Astro.props;

const primaryLogo = getPrimaryLogoPath(inst);
const downloadables = getAllDownloadableAssets(inst);

// ── SEO ────────────────────────────────────────────────────────────────
const siteUrl = Astro.site?.origin || 'https://identitate.eu';
const canonicalUrl = `${siteUrl}/institution/${inst.slug}`;
const absoluteLogo = primaryLogo ? `${siteUrl}${primaryLogo}` : undefined;

// Dynamic, keyword-rich title & description (overrideable from JSON)
const descParts: string[] = [];
descParts.push(`Descarcă logo-uri oficiale pentru ${inst.name}`);
if (inst.shortname) descParts.push(`(${inst.shortname.toUpperCase()})`);
descParts.push('în format SVG și PNG.');
if (inst.colors && inst.colors.length > 0) descParts.push(`Paletă de ${inst.colors.length} culori oficiale.`);
if (inst.typography?.primary) descParts.push(`Font: ${inst.typography.primary.family}.`);
descParts.push('Gratuit, open-source.');

const title = inst.meta.seo_title
  || `${inst.name} — Logo și Identitate Vizuală | IdentitateRO`;
const description = inst.meta.seo_description
  || descParts.join(' ');

// JSON-LD: GovernmentOrganization
const sameAsLinks: string[] = [];
if (inst.resources?.website) sameAsLinks.push(inst.resources.website);
if (inst.resources?.wikipedia_url) sameAsLinks.push(inst.resources.wikipedia_url);
if (inst.resources?.social_media) {
  Object.values(inst.resources.social_media).forEach(url => { if (url) sameAsLinks.push(url); });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'GovernmentOrganization',
  name: inst.name,
  ...(inst.shortname && { alternateName: inst.shortname.toUpperCase() }),
  url: inst.resources?.website || canonicalUrl,
  ...(absoluteLogo && { logo: absoluteLogo, image: absoluteLogo }),
  ...(inst.description && { description: inst.description }),
  ...(inst.location && {
    address: {
      '@type': 'PostalAddress',
      ...(inst.location.city && { addressLocality: inst.location.city }),
      ...(inst.location.county && { addressRegion: inst.location.county }),
      addressCountry: inst.location.country_code || 'RO',
    },
  }),
  ...(sameAsLinks.length > 0 && { sameAs: sameAsLinks }),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Acasă', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: CATEGORY_LABELS_SINGULAR[inst.category] || inst.category, item: `${siteUrl}/?categorie=${inst.category}` },
    { '@type': 'ListItem', position: 3, name: inst.shortname?.toUpperCase() || inst.name, item: canonicalUrl },
  ],
};

// ── Page data ──────────────────────────────────────────────────────────
const logoLayouts: Array<{key: string; layout: LogoLayout}> = [
  { key: 'horizontal', layout: 'horizontal' },
  { key: 'vertical', layout: 'vertical' },
  { key: 'symbol', layout: 'symbol' }
];
const qualityInfo = inst.meta.quality ? QUALITY_LABELS[inst.meta.quality] : undefined;

// Compute CDN path dynamically with fallback
const cdnLogoPath = getCdnLogoUrl(inst) ?? undefined;
---

<BaseLayout title={title} description={description} ogImage={absoluteLogo} ogType="website">
  {/* JSON-LD structured data */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} slot="head" />

  <article class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12" itemscope itemtype="https://schema.org/GovernmentOrganization">
    <!-- Header -->
    <header class="mb-10">
      {/* Breadcrumb navigation */}
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-surface-400">
          <li><a href="/" class="text-primary-500 hover:text-primary-600">Acasă</a></li>
          <li aria-hidden="true">&rsaquo;</li>
          <li><a href={`/?categorie=${inst.category}`} class="text-primary-500 hover:text-primary-600">{CATEGORY_LABELS_SINGULAR[inst.category] || inst.category}</a></li>
          <li aria-hidden="true">&rsaquo;</li>
          <li aria-current="page" class="text-surface-600 font-medium">{inst.shortname?.toUpperCase() || inst.name}</li>
        </ol>
      </nav>

      <div class="flex flex-wrap items-start gap-4">
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl sm:text-3xl font-bold text-primary-900 mb-2" itemprop="name">{inst.name}</h1>

          <div class="flex flex-wrap items-center gap-2 mb-3">
            {inst.shortname && (
              <span class="px-2 py-0.5 bg-primary-100 text-primary-700 rounded text-xs font-semibold">
                {inst.shortname.toUpperCase()}
              </span>
            )}
            <span class="px-2 py-0.5 bg-surface-100 text-surface-600 rounded text-xs">
              {CATEGORY_LABELS_SINGULAR[inst.category] || inst.category}
            </span>

          </div>

          {inst.description && (
            <p class="text-sm text-surface-500 mb-2" itemprop="description">{inst.description}</p>
          )}

          {inst.location && (
            <p class="text-xs text-surface-400 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {[inst.location.city, inst.location.county].filter(Boolean).join(', ')}
            </p>
          )}

          {inst.usage_notes && (
            <div class="mt-3 p-3 bg-amber-50 border border-amber-200 rounded text-xs text-amber-800">
              <strong>Note de utilizare:</strong> {inst.usage_notes}
            </div>
          )}
        </div>

        {/* Mini preview în header */}
        {primaryLogo && (
          <div class="shrink-0 w-20 h-20 sm:w-24 sm:h-24 bg-white border border-surface-200 rounded p-3 flex items-center justify-center">
            <img src={primaryLogo} alt={`Logo ${inst.name}`} class="max-w-full max-h-full object-contain" itemprop="logo" loading="eager" width="96" height="96" />
          </div>
        )}
      </div>

      {/* Keywords */}
      {inst.meta.keywords && inst.meta.keywords.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {inst.meta.keywords.map((keyword: string) => (
            <span class="px-2 py-1 bg-surface-50 border border-surface-200 rounded-full text-[11px] text-surface-500">
              {keyword}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- ═══ LOGO-URI ═══ -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Logo-uri
      </h2>

      {logoLayouts.map(({key, layout}) => {
        const group = inst.assets[layout];
        if (!group) return null;

        const layoutLabel = LOGO_LAYOUT_LABELS[key] || key;
        const variants = getLogoVariants(group);

        return (
          <div class="mb-6">
            <h3 class="text-sm font-medium text-primary-800 mb-3">{layoutLabel}</h3>

            {/* Preview-uri variante */}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-3">
              {variants.map(([variant, path]) => (
                <LogoVariantCard
                  variant={variant}
                  path={path}
                  layoutLabel={layoutLabel}
                  institutionName={inst.name}
                />
              ))}

              {/* PNG variant */}
              {group.png && (() => {
                const pngPath = resolveAssetPath(group.png.path, true);
                if (!pngPath) return null;
                return (
                  <div class="border border-surface-200 rounded overflow-hidden hover:shadow-md hover:border-surface-300 transition-all duration-200">
                    <div class="checkerboard aspect-[3/2] flex items-center justify-center p-6">
                      <img
                        src={pngPath}
                        alt={`Logo ${inst.name} — ${layoutLabel} PNG`}
                        class="max-w-full max-h-full object-contain"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                    <div class="p-2 bg-white flex items-center justify-between">
                      <div>
                        <span class="text-xs font-medium text-primary-900">PNG</span>
                        <span class="text-[11px] text-surface-400 ml-1">{group.png.width} × {group.png.height}px</span>
                      </div>
                      <a href={pngPath} download class="p-2 rounded hover:bg-primary-50 text-surface-400 hover:text-primary-500 transition-colors" title="Descarcă PNG">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                      </a>
                    </div>
                  </div>
                );
              })()}
            </div>
          </div>
        );
      })}
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- ═══ CULORI OFICIALE ═══ -->
      {inst.colors && inst.colors.length > 0 && (
        <section>
          <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
            Paletă de Culori
          </h2>
          <div class="space-y-3">
            {inst.colors.map((color: Color) => (
              <ColorSwatch color={color} />
            ))}
          </div>
        </section>
      )}

      <!-- ═══ TIPOGRAFIE + RESURSE ═══ -->
      <div class="space-y-8">
        {/* Tipografie */}
        {inst.typography && inst.typography.primary && (
          <section>
            <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
              </svg>
              Tipografie
            </h2>
            <div class="space-y-2">
              <div class="bg-white border border-surface-200 rounded p-3 flex items-center justify-between">
                <div>
                  <div class="font-medium text-sm text-primary-900">{inst.typography.primary.family}</div>
                  <div class="text-xs text-surface-500">Font principal</div>
                </div>
                {inst.typography.primary.url && (
                  <a
                    href={inst.typography.primary.url}
                    target="_blank"
                    rel="noopener"
                    class="text-xs text-primary-500 hover:text-primary-600"
                  >
                    Vezi font &rarr;
                  </a>
                )}
              </div>
              {inst.typography.secondary && (
                <div class="bg-white border border-surface-200 rounded p-3 flex items-center justify-between">
                  <div>
                    <div class="font-medium text-sm text-primary-900">{inst.typography.secondary.family}</div>
                    <div class="text-xs text-surface-500">Font secundar</div>
                  </div>
                  {inst.typography.secondary.url && (
                    <a
                      href={inst.typography.secondary.url}
                      target="_blank"
                      rel="noopener"
                      class="text-xs text-primary-500 hover:text-primary-600"
                    >
                      Vezi font &rarr;
                    </a>
                  )}
                </div>
              )}
            </div>
          </section>
        )}
      </div>
    </div>

    <!-- ═══ DESCĂRCĂRI RAPIDE ═══ -->
    {downloadables.length > 0 && (
      <section class="mt-10">
        <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Toate Descărcările
        </h2>
        <button id="download-zip" data-downloadables={JSON.stringify(downloadables)} data-slug={inst.slug} class="mb-4 px-4 py-2 bg-primary-500 text-white rounded hover:bg-primary-600 transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Descarcă toate ca ZIP
        </button>
      </section>
    )}

    <!-- ═══ INTEGRARE (tabs) ═══ -->
    <section class="mt-10">
      <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
        Integrare
      </h2>
      <!-- Tab buttons -->
      <div class="flex border-b border-surface-200">
        <button type="button" data-tab-btn="cdn" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-primary-500 text-primary-700 -mb-px">CDN</button>
        <button type="button" data-tab-btn="npm" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-surface-500 hover:text-surface-700 -mb-px">NPM</button>
        <button type="button" data-tab-btn="direct" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-surface-500 hover:text-surface-700 -mb-px">URL Direct</button>
      </div>
      <!-- Tab panels -->
      <div class="bg-white border border-t-0 border-surface-200 rounded-b-lg p-4">
        <!-- CDN Panel -->
        <div data-tab-panel="cdn" class="tab-panel">
          <p class="text-sm text-surface-600 mb-3">Include logo-ul direct în HTML:</p>
          <div class="relative bg-gray-50 p-3 rounded font-mono text-sm overflow-x-auto border">
            <span class="text-pink-600">&lt;img</span> <span class="text-blue-600">src</span>=<span class="text-green-600">"{cdnLogoPath}"</span> <span class="text-blue-600">alt</span>=<span class="text-green-600">"{inst.name}"</span><span class="text-pink-600">&gt;</span>
            <button type="button" class="copy-code-btn absolute top-2 right-2 p-2 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors" data-value={`<img src="${cdnLogoPath}" alt="${inst.name}">`} title="Copiază">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
            </button>
          </div>
        </div>
        <!-- NPM Panel -->
        <div data-tab-panel="npm" class="tab-panel hidden">
          <p class="text-sm text-surface-600 mb-3">Instalează pachetul și importă datele:</p>
          <div class="space-y-2">
            <div class="relative bg-gray-50 p-3 rounded font-mono text-sm border">
              <span class="text-surface-500">$</span> npm install @identitate-ro/logos
              <button type="button" class="copy-code-btn absolute top-2 right-2 p-2 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors" data-value="npm install @identitate-ro/logos" title="Copiază">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              </button>
            </div>
            <div class="relative bg-gray-50 p-3 rounded font-mono text-sm border overflow-x-auto">
              <span class="text-pink-600">import</span> logos <span class="text-pink-600">from</span> <span class="text-green-600">'@identitate-ro/logos'</span>;<br>
              <span class="text-pink-600">const</span> logo = logos.institutions.<span class="text-blue-600">find</span>(i =&gt; i.id === <span class="text-green-600">'{inst.id}'</span>);
              <button type="button" class="copy-code-btn absolute top-2 right-2 p-2 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors" data-value={`import logos from '@identitate-ro/logos';\nconst logo = logos.institutions.find(i => i.id === '${inst.id}');`} title="Copiază">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
              </button>
            </div>
          </div>
        </div>
        <!-- URL Direct Panel -->
        <div data-tab-panel="direct" class="tab-panel hidden">
          <p class="text-sm text-surface-600 mb-3">Copiază URL-ul pentru Figma, Canva sau alte aplicații:</p>
          <div class="relative bg-gray-50 p-3 rounded font-mono text-sm border break-all">
            {cdnLogoPath}
            <button type="button" class="copy-code-btn absolute top-2 right-2 p-2 rounded hover:bg-gray-200 text-gray-500 hover:text-gray-700 transition-colors" data-value={cdnLogoPath} title="Copiază URL">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
            </button>
          </div>
        </div>
      </div>
      <div class="mt-3 text-right">
        <a href="/utilizare" class="text-sm text-primary-500 hover:text-primary-600">Documentație completă &rarr;</a>
      </div>
    </section>

    <!-- ═══ RESURSE ═══ -->
    {inst.resources && (inst.resources.website || inst.resources.branding_manual || inst.resources.official_resources) && (
      <section class="mt-10">
        <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Resurse
        </h2>
        <div class="space-y-2">
          {inst.resources.website && (
            <a
              href={inst.resources.website}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 p-3 bg-white border border-surface-200 rounded hover:border-primary-300 transition-colors text-sm text-primary-600"
              itemprop="url"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
              Website Oficial
            </a>
          )}
          {inst.resources.branding_manual && (
            <a
              href={inst.resources.branding_manual}
              target="_blank"
              rel="noopener"
              class="flex items-center gap-2 p-3 bg-white border border-surface-200 rounded hover:border-primary-300 transition-colors text-sm text-primary-600"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              Manual de Identitate Vizuală
            </a>
          )}
          {inst.resources.official_resources && (
            <a
              href={inst.resources.official_resources}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 p-3 bg-white border border-surface-200 rounded hover:border-primary-300 transition-colors text-sm text-primary-600"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
              </svg>
              Resurse oficiale
            </a>
          )}
        </div>
      </section>
    )}

    <!-- ═══ METADATA (info popover) ═══ -->
    <section class="mt-10 pt-6 border-t border-surface-200">
      <div class="flex items-center justify-between">
        <span class="text-xs text-surface-400">
          Actualizat {new Date(inst.meta.last_updated).toLocaleDateString('ro-RO')}
        </span>
        <div class="relative">
          <button
            type="button"
            id="meta-info-btn"
            class="p-2 rounded-full text-surface-400 hover:text-surface-600 hover:bg-surface-100 transition-colors"
            title="Detalii tehnice"
            aria-expanded="false"
            aria-controls="meta-info-popover"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
          <div
            id="meta-info-popover"
            class="hidden absolute right-0 bottom-full mb-2 w-56 bg-white border border-surface-200 rounded-lg shadow-lg p-3 z-10"
          >
            <div class="text-xs text-surface-500 space-y-1.5">
              <div class="font-medium text-surface-700 mb-2">Detalii tehnice</div>
              <div class="flex justify-between">
                <span>Actualizat</span>
                <span class="text-surface-700">{new Date(inst.meta.last_updated).toLocaleDateString('ro-RO')}</span>
              </div>
              {inst.meta.quality && (
                <div class="flex justify-between">
                  <span>Calitate</span>
                  <span class="text-surface-700">{qualityInfo?.label || inst.meta.quality}</span>
                </div>
              )}
              <div class="flex justify-between">
                <span>ID</span>
                <span class="font-mono text-surface-700">{inst.id}</span>
              </div>
              <div class="flex justify-between">
                <span>Schema</span>
                <span class="text-surface-700">v3.0.0</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  // Copy functionality for SVG assets and colors
  document.addEventListener('DOMContentLoaded', () => {
    // Meta info popover toggle
    const metaBtn = document.getElementById('meta-info-btn');
    const metaPopover = document.getElementById('meta-info-popover');
    if (metaBtn && metaPopover) {
      metaBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !metaPopover.classList.contains('hidden');
        metaPopover.classList.toggle('hidden');
        metaBtn.setAttribute('aria-expanded', String(!isOpen));
      });
      document.addEventListener('click', () => {
        metaPopover.classList.add('hidden');
        metaBtn.setAttribute('aria-expanded', 'false');
      });
      metaPopover.addEventListener('click', (e) => e.stopPropagation());
    }

    // Tab switching for Integrare section
    const tabBtns = document.querySelectorAll('[data-tab-btn]');
    const tabPanels = document.querySelectorAll('[data-tab-panel]');
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = (btn as HTMLElement).dataset.tabBtn;
        // Update buttons
        tabBtns.forEach(b => {
          const el = b as HTMLElement;
          if (el.dataset.tabBtn === tabId) {
            el.classList.add('border-primary-500', 'text-primary-700');
            el.classList.remove('border-transparent', 'text-surface-500');
          } else {
            el.classList.remove('border-primary-500', 'text-primary-700');
            el.classList.add('border-transparent', 'text-surface-500');
          }
        });
        // Update panels
        tabPanels.forEach(p => {
          const el = p as HTMLElement;
          if (el.dataset.tabPanel === tabId) {
            el.classList.remove('hidden');
          } else {
            el.classList.add('hidden');
          }
        });
      });
    });

    const copyButtons = document.querySelectorAll('.copy-btn, .copy-color-btn, .copy-code-btn');

    copyButtons.forEach(button => {
      button.addEventListener('click', async (e) => {
        e.stopPropagation();
        e.preventDefault();

        const btn = e.currentTarget as HTMLButtonElement;
        const isColorBtn = btn.classList.contains('copy-color-btn');
        const isCodeBtn = btn.classList.contains('copy-code-btn');
        
        try {
          let textToCopy = '';

          if (isColorBtn) {
            // Copy color value directly from data-value
            textToCopy = btn.dataset.value!;
          } else if (isCodeBtn) {
            // Copy code snippet directly from data-value
            textToCopy = btn.dataset.value!;
          } else {
            // Copy asset (existing logic)
            const assetPath = btn.dataset.assetPath!;
            const assetFormat = btn.dataset.assetFormat!;

            if (assetFormat === 'svg') {
              const response = await fetch(assetPath);
              textToCopy = await response.text();
            } else {
              textToCopy = window.location.origin + assetPath;
            }
          }

          await navigator.clipboard.writeText(textToCopy);

          // Visual feedback
          const originalIcon = btn.innerHTML;
          btn.innerHTML = `
            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          `;
          setTimeout(() => { btn.innerHTML = originalIcon; }, 2000);

        } catch (err) {
          console.error('Failed to copy:', err);
          const originalIcon = btn.innerHTML;
          btn.innerHTML = `
            <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          `;
          setTimeout(() => { btn.innerHTML = originalIcon; }, 2000);
        }
      });
    });

    // Accessibility contrast checker
    function hexToRgb(hex: string): [number, number, number] | null {
      const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? [
        parseInt(result[1], 16),
        parseInt(result[2], 16),
        parseInt(result[3], 16)
      ] : null;
    }

    function getRelativeLuminance(r: number, g: number, b: number): number {
      const [rs, gs, bs] = [r, g, b].map(c => {
        c = c / 255;
        return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
      });
      return 0.2126 * rs + 0.7152 * gs + 0.0722 * bs;
    }

    function getContrastRatio(hex1: string, hex2: string): number {
      const rgb1 = hexToRgb(hex1);
      const rgb2 = hexToRgb(hex2);
      if (!rgb1 || !rgb2) return 1;
      const l1 = getRelativeLuminance(rgb1[0], rgb1[1], rgb1[2]);
      const l2 = getRelativeLuminance(rgb2[0], rgb2[1], rgb2[2]);
      const lighter = Math.max(l1, l2);
      const darker = Math.min(l1, l2);
      return (lighter + 0.05) / (darker + 0.05);
    }

    const badges = document.querySelectorAll<HTMLElement>('.accessibility-badge');
    badges.forEach(badge => {
      const hex = badge.dataset.hex;
      if (!hex) return;
      const contrastWhite = getContrastRatio(hex, '#FFFFFF');
      let level = '';
      let textClass = '';
      let title = '';
      let showInfo = true;
      if (contrastWhite >= 7) {
        level = 'AAA';
        textClass = 'text-blue-600';
        title = 'Contrast AAA (≥7:1) - Excelent pentru text pe fundal alb';
      } else if (contrastWhite >= 4.5) {
        level = 'AA';
        textClass = 'text-green-600';
        title = 'Contrast AA (≥4.5:1) - Acceptabil pentru text pe fundal alb';
      } else {
        level = 'N/A';
        textClass = 'text-red-600';
        title = 'Contrast insuficient (<4.5:1) - Nu este potrivit pentru text pe fundal alb';
        showInfo = false;
      }
      const levelText = badge.querySelector('.level-text');
      const infoIcon = badge.querySelector('.info-icon');
      const warningIcon = badge.querySelector('.warning-icon');
      if (levelText) {
        levelText.textContent = level;
        levelText.classList.add(textClass);
      }
      if (infoIcon) {
        infoIcon.classList.toggle('hidden', !showInfo);
      }
      if (warningIcon) {
        warningIcon.classList.toggle('hidden', showInfo);
      }
      badge.title = title;
    });

    // ZIP download functionality
    const downloadZipBtn = document.getElementById('download-zip') as HTMLButtonElement;
    if (downloadZipBtn) {
      downloadZipBtn.addEventListener('click', async () => {
        const downloadables = JSON.parse(downloadZipBtn.dataset.downloadables || '[]');
        const slug = downloadZipBtn.dataset.slug || 'logos';

        // Lazy-load JSZip
        // @ts-ignore - CDN dynamic import
        const { default: JSZip } = await import('https://cdn.jsdelivr.net/npm/jszip@3.10.1/+esm');

        // Show loading state
        const originalText = downloadZipBtn.innerHTML;
        downloadZipBtn.innerHTML = `
          <svg class="w-4 h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          Se pregătește ZIP...
        `;
        downloadZipBtn.disabled = true;

        try {
          const zip = new JSZip();
          for (const asset of downloadables) {
            const response = await fetch(asset.path);
            const blob = await response.blob();
            zip.file(asset.label + '.' + asset.format, blob);
          }

          const content = await zip.generateAsync({ type: 'blob' });
          const url = URL.createObjectURL(content);
          const a = document.createElement('a');
          a.href = url;
          a.download = `${slug}-logos.zip`;
          a.click();
          URL.revokeObjectURL(url);

          // Success feedback
          downloadZipBtn.innerHTML = `
            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            ZIP descărcat!
          `;
          setTimeout(() => {
            downloadZipBtn.innerHTML = originalText;
            downloadZipBtn.disabled = false;
          }, 2000);
        } catch (err) {
          console.error('Failed to create ZIP:', err);
          downloadZipBtn.innerHTML = `
            <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
            Eroare
          `;
          setTimeout(() => {
            downloadZipBtn.innerHTML = originalText;
            downloadZipBtn.disabled = false;
          }, 2000);
        }
      });
    }
  });
</script>


