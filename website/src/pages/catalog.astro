---
import BaseLayout from '../layouts/BaseLayout.astro';
import institutionIndex from '../data/institutions-index.json';
import { resolveAssetPath, CDN_VERSION } from '../lib/cdn-helpers';
import {
  CATEGORY_LABELS,
  CATEGORY_LABELS_SINGULAR,
  LOGO_LAYOUT_LABELS,
  LOGO_VARIANT_LABELS,
  COLOR_USAGE_LABELS,
  QUALITY_LABELS,
} from '../lib/labels';
import type { Institution } from '../types/institution';

const CATEGORY_ORDER = [
  'guvern', 'minister', 'agentie', 'autoritate', 'primarie',
  'consiliu-judetean', 'prefectura', 'proiect-ue', 'institutie-cultura', 'altele',
];

const allInstitutions = institutionIndex.institutions as unknown as Institution[];

const categories = CATEGORY_ORDER
  .map(value => ({
    value,
    label: CATEGORY_LABELS[value] || value,
    count: allInstitutions.filter(i => i.category === value).length,
  }))
  .filter(c => c.count > 0);

const institutionsByCategory = categories.reduce((acc, cat) => {
  acc[cat.value] = allInstitutions.filter(i => i.category === cat.value);
  return acc;
}, {} as Record<string, Institution[]>);

const title = "Catalog — IdentitateRO";
const description = "Explorează toate logo-urile instituțiilor publice din România";

const institutionsJson = JSON.stringify(allInstitutions);
const categoryLabelsSingularJson = JSON.stringify(CATEGORY_LABELS_SINGULAR);
const logoLayoutLabelsJson = JSON.stringify(LOGO_LAYOUT_LABELS);
const logoVariantLabelsJson = JSON.stringify(LOGO_VARIANT_LABELS);
const colorUsageLabelsJson = JSON.stringify(COLOR_USAGE_LABELS);
const qualityLabelsJson = JSON.stringify(QUALITY_LABELS);
const cdnVersion = CDN_VERSION;
---

<BaseLayout title={title} description={description} ogType="website">
  <!-- Catalog: three-pane layout: categories | institutions | detail -->
  <div class="flex h-[calc(100vh-3rem)] overflow-hidden">

    <!-- ═══ SIDEBAR 1: Categories ═══ -->
    <aside
      id="sidebar-categories"
      class="w-48 shrink-0 border-r border-surface-200 bg-surface-50 hidden lg:flex lg:flex-col"
    >
      <div class="px-3 py-3 border-b border-surface-100 space-y-2">
        <span class="text-[11px] font-semibold text-surface-400 uppercase tracking-wider">Categorii</span>
        <div class="relative">
          <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-surface-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            type="text"
            id="catalog-search"
            placeholder="Caută..."
            class="w-full pl-7 pr-8 py-1.5 text-sm border border-surface-200 rounded focus:outline-none focus:border-primary-400"
          />
          <button
            type="button"
            id="search-clear"
            class="absolute right-2 top-1/2 -translate-y-1/2 text-surface-300 hover:text-surface-500 hidden"
            aria-label="Golește căutarea"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
      <nav class="flex-1 overflow-y-auto py-2 space-y-0.5 px-2">
        {categories.map((cat, i) => (
          <button
            type="button"
            data-category-btn={cat.value}
            class:list={[
              "category-btn w-full text-left px-3 py-2 rounded text-sm transition-colors flex items-center justify-between",
              i === 0
                ? "bg-primary-50 text-primary-700 font-medium"
                : "text-surface-700 hover:bg-surface-100"
            ]}
          >
            <span class="truncate">{cat.label}</span>
            <span class="text-xs text-surface-400 tabular-nums">{cat.count}</span>
          </button>
        ))}
      </nav>
    </aside>

    <!-- ═══ SIDEBAR 2: Institutions ═══ -->
    <aside
      id="sidebar-institutions"
      class="w-60 shrink-0 border-r border-surface-200 bg-white hidden lg:flex lg:flex-col"
    >
      <!-- Sort header -->
      <div class="px-3 py-2 border-b border-surface-100">
        <div class="flex items-center gap-1">
          <span class="text-[11px] text-surface-400 flex-1" id="sidebar-count"></span>
          <button type="button" id="sort-az" data-sort="az" class="sort-btn px-2 py-0.5 rounded text-[11px] font-medium bg-primary-50 text-primary-600" title="Sortare A→Z">A–Z</button>
          <button type="button" id="sort-za" data-sort="za" class="sort-btn px-2 py-0.5 rounded text-[11px] font-medium text-surface-400 hover:bg-surface-100" title="Sortare Z→A">Z–A</button>
        </div>
      </div>
      <!-- Institution list -->
      <nav id="institutions-list" class="flex-1 overflow-y-auto py-1">
        {categories.map((cat) => (
          <div data-category-group={cat.value} class="institution-group">
            <div class="px-3 py-1.5 text-[10px] font-semibold text-surface-400 uppercase tracking-wider sticky top-0 bg-white/95 backdrop-blur-sm z-10">
              {cat.label}
            </div>
            {institutionsByCategory[cat.value].map((inst: Institution) => {
              const logoSrc = inst.assets?.main?.color
                ? `https://cdn.jsdelivr.net/npm/@identitate-ro/logos@${cdnVersion}${inst.assets.main.color}`
                : null;
              return (
                <button
                  type="button"
                  data-institution-btn={inst.slug}
                  class="institution-btn w-full text-left px-3 py-2 hover:bg-surface-50 transition-colors flex items-center gap-2 group"
                  data-name={`${inst.name} ${inst.shortname || ''}`}
                  data-category={inst.category}
                >
                  <span class="w-7 h-7 rounded border border-surface-100 bg-white flex items-center justify-center shrink-0 overflow-hidden">
                    {logoSrc
                      ? <img src={logoSrc} alt="" class="w-6 h-6 object-contain" loading="lazy" />
                      : <span class="text-surface-300 text-[10px]">?</span>
                    }
                  </span>
                  <span class="truncate text-sm text-surface-700 group-hover:text-primary-700">
                    {inst.shortname?.toUpperCase() || inst.name}
                  </span>
                </button>
              );
            })}
          </div>
        ))}
      </nav>
    </aside>

    <!-- ═══ MAIN: Institution Detail ═══ -->
    <main id="catalog-main" class="flex-1 min-w-0 overflow-y-auto bg-white">
      <!-- Placeholder while no institution is loaded -->
      <div id="catalog-placeholder" class="flex-col items-center justify-center h-full text-center p-12 hidden">
        <svg class="w-16 h-16 text-surface-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-surface-400 text-sm">Selectează o instituție din listă</p>
      </div>
      <!-- Detail content injected by JS -->
      <div id="institution-detail" class="p-6 max-w-4xl mx-auto"></div>
    </main>
  </div>
</BaseLayout>

<script define:vars={{
  institutionsJson,
  categoryLabelsSingularJson,
  logoLayoutLabelsJson,
  logoVariantLabelsJson,
  colorUsageLabelsJson,
  qualityLabelsJson,
  cdnVersion,
}}>
// ─── Bootstrap ──────────────────────────────────────────────────────────────
const institutions = JSON.parse(institutionsJson);
const CATEGORY_LABELS_SINGULAR = JSON.parse(categoryLabelsSingularJson);
const LAYOUT_LABELS  = JSON.parse(logoLayoutLabelsJson);
const VARIANT_LABELS = JSON.parse(logoVariantLabelsJson);
const USAGE_LABELS   = JSON.parse(colorUsageLabelsJson);
const QUALITY_LABELS = JSON.parse(qualityLabelsJson);

const CDN_BASE = `https://cdn.jsdelivr.net/npm/@identitate-ro/logos@${cdnVersion}`;
const SITE = 'https://identitate.eu';

/** Build an index map by slug */
const bySlug = {};
institutions.forEach(i => { bySlug[i.slug] = i; });

// ─── DOM refs ────────────────────────────────────────────────────────────────
const categoryBtns   = document.querySelectorAll('.category-btn');
const institutionBtns = document.querySelectorAll('.institution-btn');
const institutionGroups = document.querySelectorAll('.institution-group');
const searchInput    = document.getElementById('catalog-search');
const searchClear    = document.getElementById('search-clear');
const sortAZ         = document.getElementById('sort-az');
const sortZA         = document.getElementById('sort-za');
const sidebarCount   = document.getElementById('sidebar-count');
const detail         = document.getElementById('institution-detail');
const placeholder    = document.getElementById('catalog-placeholder');

let currentCategory  = null; // null = all
let currentSlug      = null;
let currentSort      = 'az';

// ─── Helpers ─────────────────────────────────────────────────────────────────
function escHtml(str) {
  return String(str ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function resolveUrl(path) {
  if (!path) return '';
  if (typeof path === 'object') path = path.cdn_primary || path.local || '';
  if (!path) return '';
  if (path.startsWith('http')) return path;
  if (path.startsWith('/logos/')) return `${CDN_BASE}${path}`;
  return `${SITE}${path}`;
}

function getCdnLogoUrl(inst) {
  const main = inst.assets?.main;
  if (!main) return null;
  const layout = main.type || 'horizontal';
  const variant = main.color ? 'color' : main.dark_mode ? 'dark_mode' : main.black ? 'black' : main.white ? 'white' : null;
  if (!variant) return null;
  return `${CDN_BASE}/logos/${inst.id}/${layout}/${variant}.svg`;
}

function getPrimaryLogo(inst) {
  const main = inst.assets?.main;
  if (!main) return null;
  if (main.color) return resolveUrl(main.color);
  if (main.dark_mode) return resolveUrl(main.dark_mode);
  if (main.black) return resolveUrl(main.black);
  if (main.white) return resolveUrl(main.white);
  if (main.monochrome) return resolveUrl(main.monochrome);
  if (main.png?.path) return resolveUrl(main.png.path);
  return null;
}

function getDownloadables(inst) {
  const assets = [];
  for (const layout of ['horizontal', 'vertical', 'symbol']) {
    const group = inst.assets?.[layout];
    if (!group) continue;
    for (const variant of ['color', 'dark_mode', 'white', 'black', 'monochrome']) {
      const p = group[variant];
      if (!p) continue;
      assets.push({ label: `${layout}-${variant}`, format: 'svg', path: resolveUrl(p), layout, variant });
    }
    if (group.png?.path) {
      assets.push({ label: `${layout}-png`, format: 'png', path: resolveUrl(group.png.path), layout, variant: 'png', width: group.png.width, height: group.png.height });
    }
  }
  return assets;
}

// ─── Accessibility contrast ──────────────────────────────────────────────────
function hexToRgb(hex) {
  const r = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
  return r ? [parseInt(r[1],16), parseInt(r[2],16), parseInt(r[3],16)] : null;
}
function luminance(r,g,b) {
  return [r,g,b].reduce((acc, c, i) => {
    c /= 255;
    return acc + (c <= 0.03928 ? c/12.92 : Math.pow((c+0.055)/1.055,2.4)) * [0.2126, 0.7152, 0.0722][i];
  }, 0);
}
function contrastVsWhite(hex) {
  const rgb = hexToRgb(hex);
  if (!rgb) return 1;
  const l = luminance(...rgb);
  return (1.05) / (l + 0.05);
}
function wcagBadge(hex) {
  const c = contrastVsWhite(hex);
  if (c >= 7)   return { level: 'AAA', cls: 'text-blue-600',  icon: 'info',    title: 'AAA (≥7:1)' };
  if (c >= 4.5) return { level: 'AA',  cls: 'text-green-600', icon: 'info',    title: 'AA (≥4.5:1)' };
  return             { level: 'N/A', cls: 'text-red-500',   icon: 'warning', title: '<4.5:1 — contrast insuficient' };
}

const ICONS = {
  download: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  copy: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`,
  copySm: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`,
  web: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  book: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
};

// ─── HTML Builders ────────────────────────────────────────────────────────────
function buildVariantCard(inst, variant, path, layoutLabel) {
  const isWhite = variant === 'white';
  const isDark  = variant === 'dark_mode';
  const label   = VARIANT_LABELS[variant] || variant;
  const bg      = isWhite ? 'bg-gray-800' : isDark ? 'checkerboard-dark' : 'checkerboard';
  return `
    <div class="border border-surface-200 rounded overflow-hidden hover:shadow-md hover:border-surface-300 transition-all duration-200">
      <div class="aspect-[3/2] flex items-center justify-center p-6 ${bg}">
        <img src="${escHtml(path)}" alt="Logo ${escHtml(inst.name)} — ${escHtml(layoutLabel)} ${escHtml(label)}"
             class="max-w-full max-h-full object-contain" loading="lazy" decoding="async" />
      </div>
      <div class="p-2 bg-white flex items-center justify-between">
        <div>
          <span class="text-xs font-medium text-primary-900">${escHtml(label)}</span>
          <span class="text-[11px] text-surface-400 ml-1">SVG</span>
        </div>
        <div class="flex items-center gap-0.5">
          <a href="${escHtml(path)}" download class="p-2 rounded hover:bg-primary-50 text-surface-400 hover:text-primary-500 transition-colors" title="Descarcă SVG">${ICONS.download}</a>
          <button type="button" class="copy-asset-btn p-2 rounded hover:bg-primary-50 text-surface-400 hover:text-primary-500 transition-colors" data-path="${escHtml(path)}" title="Copiază SVG">${ICONS.copy}</button>
        </div>
      </div>
    </div>`;
}

function buildPngCard(inst, group, layoutLabel) {
  const path = resolveUrl(group.png.path);
  return `
    <div class="border border-surface-200 rounded overflow-hidden hover:shadow-md hover:border-surface-300 transition-all duration-200">
      <div class="aspect-[3/2] flex items-center justify-center p-6 checkerboard">
        <img src="${escHtml(path)}" alt="Logo ${escHtml(inst.name)} — ${escHtml(layoutLabel)} PNG"
             class="max-w-full max-h-full object-contain" loading="lazy" decoding="async" />
      </div>
      <div class="p-2 bg-white flex items-center justify-between">
        <div>
          <span class="text-xs font-medium text-primary-900">PNG</span>
          ${group.png.width ? `<span class="text-[11px] text-surface-400 ml-1">${group.png.width} × ${group.png.height}px</span>` : ''}
        </div>
        <a href="${escHtml(path)}" download class="p-2 rounded hover:bg-primary-50 text-surface-400 hover:text-primary-500 transition-colors" title="Descarcă PNG">${ICONS.download}</a>
      </div>
    </div>`;
}

function buildColorsSection(colors) {
  if (!colors?.length) return '';
  const swatches = colors.map(c => {
    const {level, cls, title} = wcagBadge(c.hex);
    const usageLabel = c.usage ? (USAGE_LABELS[c.usage] || c.usage) : '';
    const rgbStr = c.rgb ? c.rgb.join(', ') : '';
    return `
      <div class="bg-white border border-surface-200 rounded p-3 flex items-start gap-3 group">
        <div class="relative w-12 h-12 rounded border border-surface-200 shrink-0">
          <div class="w-full h-full rounded" style="background-color:${escHtml(c.hex)}"></div>
          <span class="absolute -top-1 -right-1 text-[10px] font-bold px-1 py-0.5 rounded-full bg-white border border-gray-300 shadow-sm ${cls}" title="${escHtml(title)}">${escHtml(level)}</span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="font-medium text-sm text-primary-900">${escHtml(c.name)}</span>
            ${usageLabel ? `<span class="px-1.5 py-0.5 bg-surface-100 rounded text-[11px] text-surface-500">${escHtml(usageLabel)}</span>` : ''}
          </div>
          <div class="grid grid-cols-2 gap-x-4 gap-y-0.5 text-xs text-surface-500">
            <div class="font-mono flex items-center gap-1">
              ${escHtml(c.hex)}
              <button type="button" class="copy-color-btn p-1 rounded hover:bg-surface-100 text-surface-400 hover:text-surface-600 opacity-0 group-hover:opacity-100 transition" data-value="${escHtml(c.hex)}" title="Copiază HEX">${ICONS.copySm}</button>
            </div>
            ${rgbStr ? `<div class="flex items-center gap-1">RGB: ${escHtml(rgbStr)}<button type="button" class="copy-color-btn p-1 rounded hover:bg-surface-100 text-surface-400 hover:text-surface-600 opacity-0 group-hover:opacity-100 transition" data-value="rgb(${escHtml(rgbStr)})" title="Copiază RGB">${ICONS.copySm}</button></div>` : ''}
            ${c.cmyk ? `<div>CMYK: ${escHtml(c.cmyk.join(', '))}</div>` : ''}
            ${c.pantone ? `<div>Pantone ${escHtml(c.pantone)}</div>` : ''}
          </div>
        </div>
      </div>`;
  }).join('');
  return `
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
        Paletă de Culori
      </h2>
      <div class="space-y-3">${swatches}</div>
    </section>`;
}

function buildDetail(inst) {
  const primaryLogo = getPrimaryLogo(inst);
  const cdnLogo     = getCdnLogoUrl(inst) ?? '';
  const downloadables = getDownloadables(inst);
  const catLabel    = CATEGORY_LABELS_SINGULAR[inst.category] || inst.category;
  const qualityInfo = inst.meta?.quality ? QUALITY_LABELS[inst.meta.quality] : null;

  // ── Logo sections ──────────────────────────────────────────────────────────
  let logoSectionsHtml = '';
  for (const layout of ['horizontal', 'vertical', 'symbol']) {
    const group = inst.assets?.[layout];
    if (!group) continue;
    const layoutLabel = LAYOUT_LABELS[layout] || layout;
    let cards = '';
    for (const variant of ['color', 'dark_mode', 'white', 'black', 'monochrome']) {
      const p = group[variant];
      if (!p) continue;
      cards += buildVariantCard(inst, variant, resolveUrl(p), layoutLabel);
    }
    if (group.png?.path) cards += buildPngCard(inst, group, layoutLabel);
    if (!cards) continue;
    logoSectionsHtml += `
      <div class="mb-6">
        <h3 class="text-sm font-medium text-primary-800 mb-3">${escHtml(layoutLabel)}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${cards}</div>
      </div>`;
  }

  // ── Colors, Typography, Resources ─────────────────────────────────────────
  const colorsHtml = buildColorsSection(inst.colors);

  let typographyHtml = '';
  if (inst.typography?.primary) {
    const sec = inst.typography.secondary;
    typographyHtml = `
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"/></svg>
          Tipografie
        </h2>
        <div class="space-y-2">
          <div class="bg-white border border-surface-200 rounded p-3 flex items-center justify-between">
            <div>
              <div class="font-medium text-sm text-primary-900">${escHtml(inst.typography.primary.family)}</div>
              <div class="text-xs text-surface-500">Font principal</div>
            </div>
            ${inst.typography.primary.url ? `<a href="${escHtml(inst.typography.primary.url)}" target="_blank" rel="noopener" class="text-xs text-primary-500 hover:text-primary-600">Vezi font &rarr;</a>` : ''}
          </div>
          ${sec ? `
          <div class="bg-white border border-surface-200 rounded p-3 flex items-center justify-between">
            <div>
              <div class="font-medium text-sm text-primary-900">${escHtml(sec.family)}</div>
              <div class="text-xs text-surface-500">Font secundar</div>
            </div>
            ${sec.url ? `<a href="${escHtml(sec.url)}" target="_blank" rel="noopener" class="text-xs text-primary-500 hover:text-primary-600">Vezi font &rarr;</a>` : ''}
          </div>` : ''}
        </div>
      </section>`;
  }

  let resourcesHtml = '';
  if (inst.resources?.website || inst.resources?.branding_manual || inst.resources?.official_resources) {
    resourcesHtml = `
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-primary-900 mb-4 flex items-center gap-2">
