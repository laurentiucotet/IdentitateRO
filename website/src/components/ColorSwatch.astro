---
/**
 * ColorSwatch - Afișează o singură culoare cu detalii
 */
import type { Color } from '../types/institution';
import { COLOR_USAGE_LABELS } from '../lib/labels';

interface Props {
  color: Color;
}

const { color } = Astro.props;
---

<div class="bg-white border border-surface-200 rounded p-3 flex items-start gap-3 group">
  <div class="relative w-12 h-12 rounded border border-surface-200 shrink-0">
    <div class="w-full h-full rounded" style={`background-color: ${color.hex}`}></div>
    <span
      class="accessibility-badge absolute -top-1 -right-1 text-xs font-bold px-1.5 py-0.5 rounded-full bg-white border border-gray-300 shadow-sm flex items-center gap-0.5 z-10"
      data-hex={color.hex}
      title=""
    >
      <span class="level-text"></span>
      <svg class="info-icon w-3 h-3 opacity-75" fill="currentColor" viewBox="0 0 20 20">
        <path
          fill-rule="evenodd"
          d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"
          clip-rule="evenodd"></path>
      </svg>
      <svg class="warning-icon w-3 h-3 opacity-75 hidden" fill="currentColor" viewBox="0 0 20 20">
        <path
          fill-rule="evenodd"
          d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
          clip-rule="evenodd"></path>
      </svg>
    </span>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 mb-1">
      <span class="font-medium text-sm text-primary-900">{color.name}</span>
      {
        color.usage && (
          <span class="px-1.5 py-0.5 bg-surface-100 rounded text-[11px] text-surface-500">
            {COLOR_USAGE_LABELS[color.usage] || color.usage}
          </span>
        )
      }
    </div>
    <div class="grid grid-cols-2 gap-x-4 gap-y-0.5 text-xs text-surface-500">
      <div class="font-mono flex items-center gap-1">
        {color.hex}
        <button
          class="copy-color-btn p-1.5 rounded hover:bg-surface-100 text-surface-400 hover:text-surface-600 transition-colors max-sm:opacity-100 opacity-0 group-hover:opacity-100"
          data-value={color.hex}
          title="Copiază HEX"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
            ></path>
          </svg>
        </button>
      </div>
      {
        color.rgb && (
          <div class="flex items-center gap-1">
            RGB: {color.rgb.join(', ')}
            <button
              class="copy-color-btn p-1.5 rounded hover:bg-surface-100 text-surface-400 hover:text-surface-600 transition-colors max-sm:opacity-100 opacity-0 group-hover:opacity-100"
              data-value={`rgb(${color.rgb.join(', ')})`}
              title="Copiază RGB"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                />
              </svg>
            </button>
          </div>
        )
      }
      {color.cmyk && <div>CMYK: {color.cmyk.join(', ')}</div>}
      {color.pantone && <div>Pantone {color.pantone}</div>}
    </div>
  </div>
</div>
