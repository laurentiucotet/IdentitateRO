---
/**
 * LogoVariantCard - Afișează o variantă de logo (SVG sau PNG)
 */
import { LOGO_VARIANT_LABELS } from '../lib/labels';

interface Props {
  variant: string;
  path: string;
  layoutLabel: string;
  institutionName: string;
  isPng?: boolean;
  width?: number;
  height?: number;
}

const { variant, path, layoutLabel, institutionName, isPng = false, width, height } = Astro.props;

const isWhiteVariant = variant === 'white';
---

<div
  class="border border-surface-200 rounded overflow-hidden hover:shadow-md hover:border-surface-300 transition-all duration-200"
>
  <div
    class:list={[
      'aspect-[3/2] flex items-center justify-center p-6',
      isWhiteVariant ? 'bg-gray-800' : 'checkerboard',
    ]}
  >
    <img
      src={path}
      alt={`Logo ${institutionName} — ${layoutLabel} ${isPng ? 'PNG' : LOGO_VARIANT_LABELS[variant] || variant}`}
      class="max-w-full max-h-full object-contain"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="p-2 bg-white flex items-center justify-between">
    <div>
      <span class="text-xs font-medium text-primary-900">
        {isPng ? 'PNG' : LOGO_VARIANT_LABELS[variant] || variant}
      </span>
      {
        isPng && width && height && (
          <span class="text-[11px] text-surface-400 ml-1">
            {width} × {height}px
          </span>
        )
      }
      {!isPng && <span class="text-[11px] text-surface-400 ml-1">SVG</span>}
    </div>
    <div class="flex items-center gap-0.5">
      <a
        href={path}
        download
        class="p-2 rounded hover:bg-primary-50 text-surface-400 hover:text-primary-500 transition-colors"
        title={isPng ? 'Descarcă PNG' : 'Descarcă'}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
      </a>
      {
        !isPng && (
          <button
            type="button"
            class="copy-btn p-2 rounded hover:bg-primary-50 text-surface-400 hover:text-primary-500 transition-colors"
            data-asset-path={path}
            data-asset-format="svg"
            title="Copiază SVG"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
              />
            </svg>
          </button>
        )
      }
    </div>
  </div>
</div>
