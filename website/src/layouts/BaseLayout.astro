---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const { title, description, ogImage, ogType, noindex }: Props = Astro.props;

const pageTitle = title || 'Identitate.EU — Registrul Siglelor Instituțiilor Publice';
const pageDescription = description || 'Registru digital pentru logo-uri vectoriale ale instituțiilor publice din România.';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage || new URL('/og-image.png', Astro.site).href;
---

<!doctype html>
<html lang="ro" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={ogType || 'website'} />
    <meta property="og:locale" content="ro_RO" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="IdentitateRO" />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#004990" />

    <!-- Font: Public Sans (preconnect + non-blocking load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700&display=swap" /></noscript>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "IdentitateEU",
      "url": "https://identitate.eu",
      "description": "Registru digital open-source pentru identitatea vizuală a instituțiilor publice din România.",
      "inLanguage": "ro",
      "publisher": {
        "@type": "Organization",
        "name": "IdentitateEU Community",
        "url": "https://identitate.eu"
      }
    })} />

    <!-- Page-specific head content (JSON-LD, etc.) -->
    <slot name="head" />

    <title>{pageTitle}</title>

    <script type="module">
      import { inject } from "@vercel/analytics";
      inject();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
